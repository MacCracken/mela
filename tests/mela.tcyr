}

# Real on-disk extraction — pack a bundle, extract to disk, verify the files.
fn test_extraction() {
    test_group("extraction");
    var DIR = "/tmp/mela-extract";
    sys_unlink(str_data(path_join(str_from(DIR), str_from("manifest.json"))));
    sys_unlink(str_data(path_join(str_from(DIR), str_from("sandbox.json"))));

    var agent = mk_agent(str_from("extract-pkg"), str_from("d"));
    var manifest = manifest_new(agent, publisher_new(str_from("P"), str_from("k"), str_from("")), CAT_UTILITY, str_from("1.0.0"));
    var bundle = pipeline_package(manifest, generate_sandbox_profile(mk_pfconfig()));

    var n = agpkg_extract_to_dir(str_data(bundle), str_len(bundle), str_from(DIR));
    assert_eq(n, 2, "extracted 2 files");
    assert_eq(file_exists(str_data(path_join(str_from(DIR), str_from("manifest.json")))), 1, "manifest.json on disk");
    assert_eq(file_exists(str_data(path_join(str_from(DIR), str_from("sandbox.json")))), 1, "sandbox.json on disk");
    # the extracted manifest.json re-parses to the same package
    var buf = alloc(65536);
    var rn = file_read_all(str_data(path_join(str_from(DIR), str_from("manifest.json"))), buf, 65536);
    var reparsed = manifest_from_json(str_new(buf, rn));
    assert_neq(reparsed, 0, "extracted manifest re-parses");
    assert_eq(str_eq_cstr(man_name(reparsed), "extract-pkg"), 1, "extracted manifest name");

    # zip-slip entry is NOT written to disk
    var EDIR = "/tmp/mela-extract-evil";
    var evil = vec_new();
    var blob = str_from("x");
    vec_push(evil, tentry_new(str_from("../escaped.so"), str_data(blob), str_len(blob)));
    vec_push(evil, tentry_new(str_from("ok.txt"),        str_data(blob), str_len(blob)));
    var ebundle = _gzip_str(_tar_build(evil));
    var en = agpkg_extract_to_dir(str_data(ebundle), str_len(ebundle), str_from(EDIR));
    assert_eq(en, 1, "only the safe entry extracted");
    assert_eq(file_exists(str_data(path_join(str_from(EDIR), str_from("ok.txt")))), 1, "safe file written");
    assert_eq(file_exists("/tmp/mela-extract-evil/../escaped.so"), 0, "traversal file NOT written");
    return 0;
}

# End-to-end pipeline: package -> sign+log -> verify (both gates) -> install.
fn test_pipeline() {
    test_group("pipeline");
    var NOW = 1000;

    # publisher keypair + keyring
    var sk[64];
    var pk[32];
    var key_id = trust_keypair_from_seed(hex_decode("9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60", 64), &sk, &pk);
    var keyring = keyring_new();
    keyring_add_key(keyring, kv_new(key_id, NOW - 100, 0, 0, trust_hex_encode(&pk, 32)));

    # build a signed manifest (publisher key_id = signer key_id) + sandbox -> bundle
    var agent = mk_agent(str_from("test-pkg"), str_from("A test pkg"));
    var publisher = publisher_new(str_from("Test Publisher"), key_id, str_from(""));
    var manifest = manifest_new(agent, publisher, CAT_UTILITY, str_from("1.0.0"));
    var sandbox = generate_sandbox_profile(mk_pfconfig());
    var bundle = pipeline_package(manifest, sandbox);
    assert_neq(bundle, 0, "package builds bundle");

    # publish: sign + transparency log
    var tlog = tlog_new();
    var sig[64];
    var entry = pipeline_publish(tlog, bundle, &sk, &sig, NOW);
    assert_eq(tlog_len(tlog), 1, "publish logged");
    assert_eq(tlog_verify_chain(tlog), 1, "transparency chain valid");

    # capability surface (sandbox is disclosed pre-install)
    var surfaced = pipeline_extract_sandbox(bundle);
    assert_neq(surfaced, 0, "sandbox surfaced");
    assert_eq(str_eq_cstr(sbprofile_seccomp_mode(surfaced), "desktop"), 1, "surfaced seccomp");

    # install — happy path: both gates pass (digest = the logged content_hash)
    var reg = registry_in_memory();
    var content_hash = log_content_hash(entry);
    var res = pipeline_install(reg, keyring, bundle, &sig, 64, content_hash, NOW);
    assert_neq(res, 0, "install succeeds");
    assert_eq(registry_len(reg), 1, "package installed");
    assert_neq(registry_get_package(reg, str_from("test-pkg")), 0, "installed package present");

    # reject: tampered bundle — sig was over the original; verifying a DIFFERENT
    # bundle with the same key fails gate 1.
    var manifest2 = manifest_new(mk_agent(str_from("evil-pkg"), str_from("evil")), publisher, CAT_UTILITY, str_from("9.9.9"));
    var bundle2 = pipeline_package(manifest2, sandbox);
    var reg2 = registry_in_memory();
    assert_eq(pipeline_install(reg2, keyring, bundle2, &sig, 64, str_from(""), NOW), 0, "tampered bundle rejected");
    assert_eq(registry_is_empty(reg2), 1, "nothing installed after tamper");

    # reject: digest mismatch — gate 2
    var reg3 = registry_in_memory();
    assert_eq(pipeline_install(reg3, keyring, bundle, &sig, 64, str_from("deadbeef"), NOW), 0, "digest mismatch rejected");

    # reject: unsigned / untrusted publisher — empty keyring fails gate 1
    var reg4 = registry_in_memory();
    assert_eq(pipeline_install(reg4, keyring_new(), bundle, &sig, 64, str_from(""), NOW), 0, "untrusted publisher rejected");

    # reject: wrong key in keyring (different pubkey under the same key_id)
    var sk2[64];
    var pk2[32];
    trust_keypair_from_seed(hex_decode("4ccd089b28ff96da9db6c346ec114e0f5b8a319f35aba624da8cf6ed4fb8a6fb", 64), &sk2, &pk2);
    var kr_wrong = keyring_new();
    keyring_add_key(kr_wrong, kv_new(key_id, NOW - 100, 0, 0, trust_hex_encode(&pk2, 32)));
    var reg5 = registry_in_memory();
    assert_eq(pipeline_install(reg5, kr_wrong, bundle, &sig, 64, str_from(""), NOW), 0, "wrong key rejected");
    return 0;
}

# Archive pack -> inspect round-trip (build->inspect->validate done-when).
fn test_agpkg_archive() {
    test_group("agpkg-archive");
    var DIR = "/tmp/mela-pack-build";
    # set up a valid build dir with engine, aot, and two asset files
    setup_build(DIR, "lib/libflutter_engine.so", 1, 1);
    file_write_all(str_data(path_join(str_from(DIR), str_from("flutter_assets/AssetManifest.json"))), "{}", 2);
    file_write_all(str_data(path_join(str_from(DIR), str_from("flutter_assets/FontManifest.json"))), "[]", 2);

    var out = pack_flutter_app(str_from(DIR), mk_pfconfig(), str_from("/tmp/mela-pack-out"));
    assert_neq(out, 0, "pack returns path");
    assert_eq(str_eq_cstr(out, "/tmp/mela-pack-out/my-flutter-app-1.0.0.agnos-agent"), 1, "pack tarball name");
    assert_eq(file_exists(str_data(out)), 1, "tarball exists");

    var names = agpkg_inspect(out);
    assert_neq(names, 0, "inspect ok");
    assert_eq(names_contain(names, "bin/flutter_engine.so"), 1, "has engine entry");
    assert_eq(names_contain(names, "bin/my-flutter-app"),    1, "has aot entry");
    assert_eq(names_contain(names, "manifest.json"),         1, "has manifest entry");
    assert_eq(names_contain(names, "sandbox.json"),          1, "has sandbox entry");
    assert_eq(names_have_prefix(names, "assets/flutter_assets/"), 1, "has assets entries");
    return 0;
}

# flutter_packaging — parity with rust-old/src/flutter_packaging.rs (pure).
fn test_fpackaging() {
    test_group("fpackaging");

    # Display names
    assert_eq(str_eq_cstr(wayland_req_name(WL_CORE),             "core"),             1, "wl core");
    assert_eq(str_eq_cstr(wayland_req_name(WL_FRACTIONAL_SCALE), "fractional_scale"), 1, "wl fractional");
    assert_eq(str_eq_cstr(wayland_req_name(WL_XWAYLAND),         "xwayland"),         1, "wl xwayland");
    assert_eq(str_eq_cstr(display_backend_name(DB_WAYLAND),  "wayland"),  1, "db wayland");
    assert_eq(str_eq_cstr(display_backend_name(DB_XWAYLAND), "xwayland"), 1, "db xwayland");

    # is_dotted_version
    assert_eq(is_dotted_version(str_from("3.22.0")),   1, "dotted 3.22.0");
    assert_eq(is_dotted_version(str_from("0.0.1")),    1, "dotted 0.0.1");
    assert_eq(is_dotted_version(str_from("3.22")),     0, "dotted 3.22 invalid");
    assert_eq(is_dotted_version(str_from("abc")),      0, "dotted abc invalid");
    assert_eq(is_dotted_version(str_from("3.22.0.1")), 0, "dotted 4-part invalid");
    assert_eq(is_dotted_version(str_from("")),         0, "dotted empty invalid");

    # validate
    assert_eq(vec_len(validate_flutter_manifest(mk_fmanifest())), 0, "valid manifest no errors");
    var me = mk_fmanifest(); store64(me + 8, str_from(""));    # engine_version @ 8
    assert_eq(errors_contain(validate_flutter_manifest(me), "engine_version is required"), 1, "missing engine");
    var mb = mk_fmanifest(); store64(mb + 8, str_from("not-a-version"));
    assert_eq(errors_contain(validate_flutter_manifest(mb), "engine_version"), 1, "bad engine");
    var md = mk_fmanifest(); store64(md + 16, str_from(""));   # dart_version @ 16
    assert_eq(errors_contain(validate_flutter_manifest(md), "dart_version is required"), 1, "missing dart");
    var mr = mk_fmanifest(); store64(mr, str_from("native"));  # runtime @ 0
    assert_eq(errors_contain(validate_flutter_manifest(mr), "runtime must be 'flutter'"), 1, "wrong runtime");
    var mc = mk_fmanifest(); store64(mc + 24, wlvec(WL_XDG_SHELL, 0 - 1));   # only XdgShell
    assert_eq(errors_contain(validate_flutter_manifest(mc), "Core"), 1, "missing Core");
    var mx = mk_fmanifest(); store64(mx + 24, wlvec(WL_CORE, 0 - 1));        # only Core
    assert_eq(errors_contain(validate_flutter_manifest(mx), "XdgShell"), 1, "missing XdgShell");

    # determine_backend
    var caps_all = vec_new();
    vec_push(caps_all, WL_CORE); vec_push(caps_all, WL_XDG_SHELL); vec_push(caps_all, WL_XDG_DECORATION);
    vec_push(caps_all, WL_TEXT_INPUT_V3); vec_push(caps_all, WL_VIEWPORTER);
    assert_eq(determine_backend(mk_fmanifest(), caps_all), DB_WAYLAND, "backend all met");
    assert_eq(determine_backend(mk_fmanifest(), wlvec(WL_CORE, 0 - 1)), DB_XWAYLAND, "backend missing");
    assert_eq(determine_backend(mk_fmanifest(), vec_new()), DB_XWAYLAND, "backend empty caps");
    var m_noreq = mk_fmanifest(); store64(m_noreq + 24, vec_new());
    assert_eq(determine_backend(m_noreq, vec_new()), DB_WAYLAND, "backend no reqs");

    # launch config
    var cfg = build_launch_config(mk_fmanifest(), str_from("my-app"), str_from("wayland-0"), f64_div(f64_from(3), f64_from(2)));
    assert_eq(str_eq_cstr(launch_app_name(cfg), "my-app"), 1, "launch app_name");
    assert_eq(launch_display_backend(cfg), DB_WAYLAND, "launch wayland");
    assert_eq(launch_has_theme(cfg), 1, "launch has theme");
    assert_eq(str_eq_cstr(launch_theme_channel(cfg), "flutter/theme"), 1, "launch theme channel");
    var mxw = mk_fmanifest(); var wl2 = fmanifest_wayland(mxw); vec_push(wl2, WL_XWAYLAND);
    var cfgx = build_launch_config(mxw, str_from("x-app"), str_from("wayland-1"), f64_from(2));
    assert_eq(launch_display_backend(cfgx), DB_XWAYLAND, "launch xwayland");

    # env vars — wayland (with theme + accessibility channels, scale 1.25)
    var wlw = vec_new(); vec_push(wlw, WL_CORE); vec_push(wlw, WL_XDG_SHELL);
    var chw = vec_new(); vec_push(chw, str_from("flutter/theme")); vec_push(chw, str_from("flutter/accessibility"));
    var mw = fmanifest_new(str_from("flutter"), str_from("3.22.0"), str_from("3.4.0"), wlw, chw, 1);
    var cw = build_launch_config(mw, str_from("test-app"), str_from("wayland-0"), f64_div(f64_from(5), f64_from(4)));
    var ew = build_env_vars(cw);
    assert_eq(str_eq_cstr(map_get(ew, str_from("GDK_BACKEND")), "wayland"), 1, "env wayland GDK");
    assert_eq(str_eq_cstr(map_get(ew, str_from("WAYLAND_DISPLAY")), "wayland-0"), 1, "env WAYLAND_DISPLAY");
    assert_eq(str_eq_cstr(map_get(ew, str_from("FLUTTER_FORCE_SCALE_FACTOR")), "1.25"), 1, "env scale 1.25");
    assert_eq(str_eq_cstr(map_get(ew, str_from("FLUTTER_ACCESSIBILITY")), "true"), 1, "env accessibility");
    assert_eq(str_eq_cstr(map_get(ew, str_from("FLUTTER_THEME_CHANNEL")), "flutter/theme"), 1, "env theme");
    assert_eq(str_eq_cstr(map_get(ew, str_from("AGNOS_APP_NAME")), "test-app"), 1, "env app name");

    # env vars — xwayland (no theme, no accessibility)
    var wlx = vec_new(); vec_push(wlx, WL_CORE); vec_push(wlx, WL_XDG_SHELL); vec_push(wlx, WL_XWAYLAND);
    var mx2 = fmanifest_new(str_from("flutter"), str_from("3.22.0"), str_from("3.4.0"), wlx, vec_new(), 1);
    var cx = build_launch_config(mx2, str_from("x-app"), str_from("wayland-0"), f64_from(1));
    var ex = build_env_vars(cx);
    assert_eq(str_eq_cstr(map_get(ex, str_from("GDK_BACKEND")), "x11"), 1, "env xwayland GDK");
    assert_eq(str_eq_cstr(map_get(ex, str_from("DISPLAY")), ":0"), 1, "env DISPLAY");
    assert_eq(map_has(ex, str_from("FLUTTER_ACCESSIBILITY")), 0, "env no accessibility");
    assert_eq(map_has(ex, str_from("FLUTTER_THEME_CHANNEL")), 0, "env no theme");

    # layout
    var lay = layout_for_app(str_from("my-flutter-app"));
    assert_eq(str_eq_cstr(layout_engine_path(lay),     "bin/flutter_engine.so"),   1, "layout engine");
    assert_eq(str_eq_cstr(layout_app_binary_path(lay), "bin/my-flutter-app"),      1, "layout app binary");
    assert_eq(str_eq_cstr(layout_assets_path(lay),     "assets/flutter_assets/"),  1, "layout assets");
    assert_eq(str_eq_cstr(layout_manifest_path(lay),   "manifest.json"),           1, "layout manifest");
    assert_eq(str_eq_cstr(layout_sandbox_path(lay),    "sandbox.json"),            1, "layout sandbox");
    return 0;
}

# ratings persistence + serialization — parity with rust-old.
fn test_ratings_persist() {
    test_group("ratings-persist");
    var PATH = "/tmp/mela-test-ratings.json";
    sys_unlink(str_data(str_from(PATH)));

    # save + load roundtrip
    var st = mk_rstore();
    var w = rstore_save(st, str_from(PATH));
    assert_eq(w > 0, 1, "save wrote bytes");
    assert_eq(file_exists(str_data(str_from(PATH))), 1, "saved file exists");
    var loaded = rstore_load(str_from(PATH));
    assert_eq(rstore_total_count(loaded),   3, "loaded total 3");
    assert_eq(rstore_package_count(loaded), 2, "loaded packages 2");
    var sa = rstore_get_stats(loaded, str_from("pkg-a"));
    assert_eq(stats_total_ratings(sa),             2, "loaded pkg-a total 2");
    assert_eq(f64_to(stats_average_score(sa)),     4, "loaded pkg-a avg 4");

    # missing file -> empty store
    var EMPTY = "/tmp/mela-test-ratings-missing.json";
    sys_unlink(str_data(str_from(EMPTY)));
    assert_eq(rstore_total_count(rstore_load(str_from(EMPTY))), 0, "missing -> empty");

    # save empty store -> load empty
    var SE = "/tmp/mela-test-ratings-empty.json";
    sys_unlink(str_data(str_from(SE)));
    rstore_save(rstore_new(), str_from(SE));
    assert_eq(rstore_total_count(rstore_load(str_from(SE))), 0, "empty store roundtrip");

    # corrupted file -> 0
    var BAD = "/tmp/mela-test-ratings-bad.json";
    file_write_all(str_data(str_from(BAD)), "not valid json!!!", 17);
    assert_eq(rstore_load(str_from(BAD)), 0, "corrupt -> 0");

    # rating serialization
    var r = rating_new(str_from("agent-1"), str_from("pkg"), 4, 1, str_from("Good"), 100, str_from("1.0.0"));
    var r2 = rating_from_json(rating_to_json(r));
    assert_neq(r2, 0, "rating parse");
    assert_eq(str_eq_cstr(rating_agent_id(r2), "agent-1"), 1, "rating ser agent_id");
    assert_eq(rating_score(r2),                4,             "rating ser score");
    assert_eq(str_eq_cstr(rating_review(r2),   "Good"),     1, "rating ser review");

    # stats serialization
    var ss = rstore_new();
    rstore_add_rating(ss, str_from("a"), str_from("p"), 4, 0, str_from(""), str_from("1.0.0"), 1);
    var stj = stats_from_json(stats_to_json(rstore_get_stats(ss, str_from("p"))));
    assert_neq(stj, 0, "stats parse");
    assert_eq(str_eq_cstr(stats_package_name(stj), "p"), 1, "stats ser package");
    assert_eq(stats_total_ratings(stj),             1,     "stats ser total");
    return 0;
}

# sandbox_profiles — parity with rust-old/src/sandbox_profiles.rs.
fn test_sandbox() {
    test_group("sandbox");

    # Photis Nadi
    var pn = build_photis_nadi_profile();
    assert_eq(profile_preset(pn), SP_PHOTO_EDITOR, "photis preset");
    assert_eq(vec_len(profile_landlock_rules(pn)), 3, "photis 3 rules");
    assert_eq(profile_has_rule(pn, str_from("~/.local/share/photisnadi/"), str_from("rw")), 1, "photis data rule");
    assert_eq(profile_has_rule(pn, str_from("/usr/share/fonts"), str_from("ro")), 1, "photis fonts ro");
    assert_eq(nr_enabled(profile_network(pn)), 1, "photis network on");
    assert_eq(profile_allows_host(pn, str_from("*.supabase.co")), 1, "photis supabase.co");
    assert_eq(profile_allows_host(pn, str_from("*.supabase.in")), 1, "photis supabase.in");
    assert_eq(vec_len(nr_hosts(profile_network(pn))), 2, "photis 2 hosts");
    assert_eq(str_eq_cstr(profile_seccomp_mode(pn), "desktop"), 1, "photis seccomp desktop");
    assert_eq(profile_max_memory_mb(pn), 512, "photis 512mb");
    assert_eq(profile_allow_process_spawn(pn), 0, "photis no spawn");
    assert_eq(str_len(validate_profile(pn)), 0, "photis validates");

    # Aequi
    var aq = build_aequi_profile();
    assert_eq(profile_preset(aq), SP_PRODUCTIVITY, "aequi preset");
    assert_eq(vec_len(profile_landlock_rules(aq)), 5, "aequi 5 rules");
    assert_eq(profile_has_rule(aq, str_from("/usr/share/tesseract-ocr"), str_from("ro")), 1, "aequi tesseract ro");
    assert_eq(nr_enabled(profile_network(aq)), 0, "aequi network off");
    assert_eq(vec_len(nr_hosts(profile_network(aq))), 0, "aequi no hosts");
    assert_eq(str_len(validate_profile(aq)), 0, "aequi validates");

    # preset builder
    var pe = build_profile_for_preset(SP_PHOTO_EDITOR, str_from("ed"), str_from("/data/editor"));
    assert_eq(profile_preset(pe), SP_PHOTO_EDITOR, "photo preset");
    assert_eq(str_eq_cstr(profile_seccomp_mode(pe), "desktop"), 1, "photo desktop");
    assert_eq(str_len(validate_profile(pe)), 0, "photo validates");

    var pr = build_profile_for_preset(SP_PRODUCTIVITY, str_from("o"), str_from("/data/office"));
    assert_eq(nr_enabled(profile_network(pr)), 1, "productivity network on");
    assert_eq(profile_has_rule(pr, str_from("~/Documents"), str_from("rw")), 1, "productivity documents");

    var br = build_profile_for_preset(SP_BROWSER, str_from("b"), str_from("/data/browser"));
    assert_eq(profile_allow_process_spawn(br), 1, "browser spawn");
    assert_eq(profile_max_memory_mb(br), 2048, "browser 2048mb");

    var gm = build_profile_for_preset(SP_GAME, str_from("g"), str_from("/data/game"));
    assert_eq(profile_max_memory_mb(gm), 4096, "game 4096mb");
    assert_eq(profile_allow_process_spawn(gm), 0, "game no spawn");

    var cli = build_profile_for_preset(SP_CLI_TOOL, str_from("c"), str_from("/data/cli"));
    assert_eq(str_eq_cstr(profile_seccomp_mode(cli), "basic"), 1, "cli basic");
    assert_eq(nr_enabled(profile_network(cli)), 0, "cli network off");
    assert_eq(profile_allow_process_spawn(cli), 1, "cli spawn");

    var cu = build_profile_for_preset(SP_CUSTOM, str_from("x"), str_from("/data/custom"));
    assert_eq(profile_preset(cu), SP_CUSTOM, "custom preset");
    assert_eq(vec_len(profile_landlock_rules(cu)), 1, "custom 1 rule");
    assert_eq(str_len(validate_profile(cu)), 0, "custom validates");

    # GPU compute
    var gpu = build_profile_for_preset(SP_GPU_COMPUTE, str_from("synapse"), str_from("/var/lib/synapse"));
    assert_eq(profile_has_rule_containing(gpu, str_from("/dev/dri")), 1, "gpu dri");
    assert_eq(profile_has_rule_containing(gpu, str_from("nvidia")),   1, "gpu nvidia");
    assert_eq(profile_has_rule_containing(gpu, str_from("rocm")),     1, "gpu rocm");
    assert_eq(profile_allow_process_spawn(gpu), 1, "gpu spawn");
    assert_eq(profile_max_memory_mb(gpu), 4096, "gpu 4096mb");
    assert_eq(profile_allows_host(gpu, str_from("huggingface.co")), 1, "gpu huggingface");

    # validation failures
    var bad_empty = profile_new(SP_PHOTO_EDITOR, vec_new(), str_from("desktop"), nr_new(0, vec_new()), 512, 0);
    assert_eq(str_contains(validate_profile(bad_empty), str_from("at least one")), 1, "empty rules rejected");

    var bad_access = build_photis_nadi_profile();
    store64(vec_get(profile_landlock_rules(bad_access), 0) + 8, str_from("rwx"));   # access @ offset 8
    assert_eq(str_contains(validate_profile(bad_access), str_from("invalid")), 1, "bad access rejected");

    var bad_path = build_photis_nadi_profile();
    store64(vec_get(profile_landlock_rules(bad_path), 0), str_from(""));            # path @ offset 0
    assert_eq(str_contains(validate_profile(bad_path), str_from("empty path")), 1, "empty path rejected");

    var bad_seccomp = build_photis_nadi_profile();
    store64(bad_seccomp + 16, str_from("super-permissive"));                        # seccomp_mode @ offset 16
    assert_eq(str_contains(validate_profile(bad_seccomp), str_from("seccomp")), 1, "bad seccomp rejected");

    var bad_mem = build_photis_nadi_profile();
    store64(bad_mem + 32, 0);                                                        # max_memory_mb @ offset 32
    assert_eq(str_contains(validate_profile(bad_mem), str_from("max_memory_mb")), 1, "zero memory rejected");

    var bad_net = build_photis_nadi_profile();
    store64(profile_network(bad_net), 0);                                            # disable network, keep hosts
    assert_eq(str_contains(validate_profile(bad_net), str_from("allowed_hosts")), 1, "disabled net with hosts rejected");

    # serde roundtrip
    var rt = profile_from_json(profile_to_json(pn));
    assert_neq(rt, 0, "profile json parses");
    assert_eq(profile_preset(rt), profile_preset(pn), "roundtrip preset");
    assert_eq(profile_max_memory_mb(rt), profile_max_memory_mb(pn), "roundtrip memory");
    assert_eq(vec_len(profile_landlock_rules(rt)), vec_len(profile_landlock_rules(pn)), "roundtrip rules len");
    assert_eq(nr_enabled(profile_network(rt)), nr_enabled(profile_network(pn)), "roundtrip network enabled");
    return 0;
}

