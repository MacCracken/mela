# --- category.cyr ---

# category.cyr — MarketplaceCategory codec.
#
# First parity-verified slice of the Rust→Cyrius port. Ports the
# `MarketplaceCategory` enum from rust-old/src/lib.rs: a 6-variant category for
# marketplace discovery, with a Display (id -> name) and a FromStr (name -> id,
# case-insensitive, with the devtool/dev-tool and desktop-app/desktopapp
# aliases). Pure code, no deps — the foundation the manifest model builds on.

var CAT_UTILITY      = 0;
var CAT_PRODUCTIVITY = 1;
var CAT_SECURITY     = 2;
var CAT_DEVTOOL      = 3;
var CAT_DESKTOP_APP  = 4;
var CAT_SYSTEM       = 5;
var CAT_COUNT        = 6;
var CAT_PARSE_FAIL   = 0 - 1;   # i64 sentinel; a valid category is 0..CAT_COUNT.

# Display: category id -> canonical lowercase name (cstring pointer).
# Returns "" for an out-of-range id. Mirrors Rust's `impl Display`.
fn cat_name(cat): i64 {
    if (cat == CAT_UTILITY)      { return "utility"; }
    if (cat == CAT_PRODUCTIVITY) { return "productivity"; }
    if (cat == CAT_SECURITY)     { return "security"; }
    if (cat == CAT_DEVTOOL)      { return "devtool"; }
    if (cat == CAT_DESKTOP_APP)  { return "desktop-app"; }
    if (cat == CAT_SYSTEM)       { return "system"; }
    return "";
}

# ASCII-lowercase cstring `s` into `out` (NUL-terminated). `out` must hold
# strlen(s)+1 bytes. Returns `out`. (Rust used `s.to_lowercase()`.)
fn cat_lower(s, out): i64 {
    var i = 0;
    var c = load8(s + i);
    while (c != 0) {
        if (c >= 65) {
            if (c <= 90) { c = c + 32; }   # 'A'..'Z' -> 'a'..'z'
        }
        store8(out + i, c);
        i = i + 1;
        c = load8(s + i);
    }
    store8(out + i, 0);
    return out;
}

# FromStr: parse a cstring -> category id, or CAT_PARSE_FAIL on an unknown name.
# Case-insensitive; accepts the dev-tool / desktopapp aliases (Rust parity).
fn cat_parse(s): i64 {
    if (s == 0) { return CAT_PARSE_FAIL; }
    var lower[64];
    cat_lower(s, &lower);
    if (streq(&lower, "utility"))      { return CAT_UTILITY; }
    if (streq(&lower, "productivity")) { return CAT_PRODUCTIVITY; }
    if (streq(&lower, "security"))     { return CAT_SECURITY; }
    if (streq(&lower, "devtool"))      { return CAT_DEVTOOL; }
    if (streq(&lower, "dev-tool"))     { return CAT_DEVTOOL; }
    if (streq(&lower, "desktop-app"))  { return CAT_DESKTOP_APP; }
    if (streq(&lower, "desktopapp"))   { return CAT_DESKTOP_APP; }
    if (streq(&lower, "system"))       { return CAT_SYSTEM; }
    return CAT_PARSE_FAIL;
}

# --- manifest.cyr ---

# manifest.cyr — marketplace manifest model.
#
# Ports the manifest half of rust-old/src/lib.rs: the `is_valid_semver` helper,
# `PublisherInfo`, and `MarketplaceManifest` (validate / qualified_name) plus a
# hand-written JSON codec (wire format pinned in docs/adr/0001).
#
# Strings are the stdlib `Str` fat-pointer ({data; len}) to interop with
# agnostik's AgentManifest (amanifest_name / _version / _description), which the
# manifest flattens. Structs are 8-byte fields via load64/store64 at offsets.

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Index of the first '-' in [data, data+n), or n if none. Mirrors the
# `splitn(2, '-')` split point in the Rust is_valid_semver.
fn semver_version_part_len(data, n): i64 {
    var i = 0;
    var found = n;            # default: no dash -> whole string is version_part
    while (i < n) {
        if (load8(data + i) == 45) {          # '-'
            if (found == n) { found = i; }     # first dash only
        }
        i = i + 1;
    }
    return found;
}

# Basic semver: major.minor.patch with an optional `-prerelease` suffix; the
# three dot-separated segments before the first '-' must each be a non-empty
# run of ASCII digits. Mirrors rust-old `is_valid_semver` (splitn(2,'-') →
# split('.') == 3 segments → each `.parse::<u64>().is_ok()`).
#
# Divergence (documented): Rust's u64 parse also rejects a segment that
# overflows u64; this port checks digit-structure only, so a >20-digit segment
# is accepted here. No oracle fixture exercises that corner.
fn is_valid_semver(v: Str): i64 {
    var data = str_data(v);
    var n = str_len(v);
    var vp = semver_version_part_len(data, n);   # length of the version part
    var segs = 0;
    var seg_len = 0;
    var bad = 0;
    var i = 0;
    while (i < vp) {
        var c = load8(data + i);
        if (c == 46) {                # '.' — segment boundary
            if (seg_len == 0) { bad = 1; }    # empty segment fails u64 parse
            segs = segs + 1;
            seg_len = 0;
        } else {
            if (c < 48) { bad = 1; }          # not a digit
            if (c > 57) { bad = 1; }
            seg_len = seg_len + 1;
        }
        i = i + 1;
    }
    # account for the final segment (no trailing '.')
    if (seg_len == 0) { bad = 1; }
    segs = segs + 1;
    if (segs != 3) { return 0; }
    if (bad == 1) { return 0; }
    return 1;
}

# ---------------------------------------------------------------------------
# PublisherInfo — { name, key_id, homepage }
# ---------------------------------------------------------------------------

fn publisher_new(name: Str, key_id: Str, homepage: Str): i64 {
    var p = alloc(24);
    store64(p,      name);
    store64(p + 8,  key_id);
    store64(p + 16, homepage);
    return p;
}

fn pub_name(p): Str     { return load64(p); }
fn pub_key_id(p): Str   { return load64(p + 8); }
fn pub_homepage(p): Str { return load64(p + 16); }

# ---------------------------------------------------------------------------
# MarketplaceManifest
# ---------------------------------------------------------------------------
#
# Flattens agnostik's AgentManifest (the agent body — `name`@0 / `description`@8,
# both Str) and layers marketplace metadata on top. The agent's *version* is
# carried as a mela-owned Str descriptor (offset 24), NOT agnostik's structured
# Version, so validate() can reproduce the Rust oracle's empty-version and
# invalid-semver checks (agnostik's Version is always well-formed). See
# docs/adr/0002.
#
# Layout (8-byte fields):
#   0  agent              (agnostik AgentManifest*)
#   8  publisher          (PublisherInfo*)
#   16 category           (i64; CAT_* from category.cyr)
#   24 version            (Str — validated descriptor)
#   32 runtime            (Str)
#   40 screenshots        (Vec<Str>)
#   48 changelog          (Str)
#   56 min_agnos_version  (Str)
#   64 dependencies       (Str-keyed map: name -> version constraint)
#   72 tags               (Vec<Str>)

fn mela_manifest_new(agent, publisher, category, version: Str): i64 {
    var m = alloc(80);
    store64(m,      agent);
    store64(m + 8,  publisher);
    store64(m + 16, category);
    store64(m + 24, version);
    store64(m + 32, str_from(""));      # runtime
    store64(m + 40, vec_new());         # screenshots
    store64(m + 48, str_from(""));      # changelog
    store64(m + 56, str_from(""));      # min_agnos_version
    store64(m + 64, map_new_str());     # dependencies
    store64(m + 72, vec_new());         # tags
    return m;
}

fn man_agent(m)              { return load64(m); }
fn man_publisher(m)          { return load64(m + 8); }
fn man_category(m): i64      { return load64(m + 16); }
fn man_version(m): Str       { return load64(m + 24); }
fn man_runtime(m): Str       { return load64(m + 32); }
fn man_screenshots(m)        { return load64(m + 40); }
fn man_changelog(m): Str     { return load64(m + 48); }
fn man_min_agnos_version(m): Str { return load64(m + 56); }
fn man_dependencies(m)       { return load64(m + 64); }
fn man_tags(m)               { return load64(m + 72); }

fn man_set_runtime(m, v: Str)           { store64(m + 32, v); return 0; }
fn man_set_changelog(m, v: Str)         { store64(m + 48, v); return 0; }
fn man_set_min_agnos_version(m, v: Str) { store64(m + 56, v); return 0; }

# Convenience: the flattened agent identity (off agnostik's AgentManifest).
fn man_name(m): Str        { return amanifest_name(man_agent(m)); }
fn man_description(m): Str { return amanifest_description(man_agent(m)); }

# True (1) if `name` contains any char outside [a-z], [0-9], '-'. Mirrors the
# Rust `chars().all(|c| is_ascii_lowercase || is_ascii_digit || c == '-')`.
fn manifest_name_chars_invalid(name: Str): i64 {
    var data = str_data(name);
    var n = str_len(name);
    var i = 0;
    var bad = 0;
    while (i < n) {
        var c = load8(data + i);
        var ok = 0;
        if (c >= 97) { if (c <= 122) { ok = 1; } }   # a-z
        if (c >= 48) { if (c <= 57)  { ok = 1; } }    # 0-9
        if (c == 45) { ok = 1; }                       # '-'
        if (ok == 0) { bad = 1; }
        i = i + 1;
    }
    return bad;
}

# validate() — returns a Vec<Str> of error messages (empty Vec = valid).
# Mirrors rust-old MarketplaceManifest::validate, in the same rule order:
# name required / <=128 / charset, version required / semver, description
# required, publisher.name required, publisher.key_id required.
fn manifest_validate(m): i64 {
    var errors = vec_new();
    var name = man_name(m);
    var ver  = man_version(m);
    var desc = man_description(m);
    var publ = man_publisher(m);

    if (str_len(name) == 0) {
        vec_push(errors, str_from("name is required"));
    }
    if (str_len(name) > 128) {
        vec_push(errors, str_from("name must be 128 characters or fewer"));
    }
    if (str_len(name) != 0) {
        if (manifest_name_chars_invalid(name) == 1) {
            vec_push(errors, str_from("name must contain only lowercase letters, digits, and hyphens"));
        }
    }
    if (str_len(ver) == 0) {
        vec_push(errors, str_from("version is required"));
    }
    if (str_len(ver) != 0) {
        if (is_valid_semver(ver) == 0) {
            # Rust: format!("version '{}' is not valid semver", version)
            var msg = str_cat(str_cat(str_from("version '"), ver), str_from("' is not valid semver"));
            vec_push(errors, msg);
        }
    }
    if (str_len(desc) == 0) {
        vec_push(errors, str_from("description is required"));
    }
    if (str_len(pub_name(publ)) == 0) {
        vec_push(errors, str_from("publisher.name is required"));
    }
    if (str_len(pub_key_id(publ)) == 0) {
        vec_push(errors, str_from("publisher.key_id is required"));
    }
    return errors;
}

# Lowercase a Str and replace ' ' with '-' into a fresh Str. Mirrors Rust
# `name.to_lowercase().replace(' ', "-")` (space isn't a letter and hyphen
# isn't uppercase, so the two operations commute).
fn manifest_lower_replace_space(s: Str): Str {
    var n = str_len(s);
    var src = str_data(s);
    var buf = alloc(n + 1);
    var i = 0;
    while (i < n) {
        var c = load8(src + i);
        if (c == 32) { c = 45; }                         # ' ' -> '-'
        if (c >= 65) { if (c <= 90) { c = c + 32; } }     # A-Z -> a-z
        store8(buf + i, c);
        i = i + 1;
    }
    store8(buf + n, 0);
    return str_new(buf, n);
}

# qualified_name() — `publisher/agent-name`, publisher lowercased + spaced→hyphen.
fn manifest_qualified_name(m): Str {
    var lowered = manifest_lower_replace_space(pub_name(man_publisher(m)));
    return str_cat(str_cat(lowered, str_from("/")), man_name(m));
}

# ---------------------------------------------------------------------------
# JSON codec (wire format pinned in docs/adr/0001)
# ---------------------------------------------------------------------------
#
# category serializes as the serde PascalCase variant name (NOT the cat_name
# Display form) — the codec carries its own enum mapping per ADR-0001.

fn cat_json_name(cat): Str {
    if (cat == CAT_UTILITY)      { return str_from("Utility"); }
    if (cat == CAT_PRODUCTIVITY) { return str_from("Productivity"); }
    if (cat == CAT_SECURITY)     { return str_from("Security"); }
    if (cat == CAT_DEVTOOL)      { return str_from("DevTool"); }
    if (cat == CAT_DESKTOP_APP)  { return str_from("DesktopApp"); }
    if (cat == CAT_SYSTEM)       { return str_from("System"); }
    return str_from("");
}

fn cat_json_parse(s: Str): i64 {
    if (str_eq_cstr(s, "Utility") == 1)      { return CAT_UTILITY; }
    if (str_eq_cstr(s, "Productivity") == 1) { return CAT_PRODUCTIVITY; }
    if (str_eq_cstr(s, "Security") == 1)     { return CAT_SECURITY; }
    if (str_eq_cstr(s, "DevTool") == 1)      { return CAT_DEVTOOL; }
    if (str_eq_cstr(s, "DesktopApp") == 1)   { return CAT_DESKTOP_APP; }
    if (str_eq_cstr(s, "System") == 1)       { return CAT_SYSTEM; }
    return CAT_PARSE_FAIL;
}

# String value of object field `key`, or "" if absent / not a string
# (serde #[serde(default)] semantics).
fn _man_jstr(obj, key): Str {
    var v = json_v_obj_get(obj, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}

# Build a JTAG_ARR of the Str elements of a Vec<Str>.
fn _man_arr_from_vec(v): i64 {
    var arr = json_v_arr_new();
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        json_v_arr_push(arr, json_v_str_new(vec_get(v, i)));
        i = i + 1;
    }
    return arr;
}

# Append each string element of JSON array `arr` into Vec<Str> `dst`.
fn _man_vec_from_arr(arr, dst): i64 {
    if (json_v_is_arr(arr) == 0) { return 0; }
    var n = json_v_arr_len(arr);
    var i = 0;
    while (i < n) {
        var el = json_v_arr_get(arr, i);
        if (json_v_is_str(el) == 1) { vec_push(dst, json_v_str(el)); }
        i = i + 1;
    }
    return 0;
}

# publisher_to_json / from_json — { name, key_id, homepage }.
fn publisher_to_json(p): Str {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("name"),     json_v_str_new(pub_name(p)));
    json_v_obj_set(o, str_from("key_id"),   json_v_str_new(pub_key_id(p)));
    json_v_obj_set(o, str_from("homepage"), json_v_str_new(pub_homepage(p)));
    return json_v_build(o);
}

fn publisher_from_json(json: Str): i64 {
    # json_v_parse_str (explicit buf+len) — the Str-arg wrapper mis-marshals
    # the fat pointer through its untyped param (reads len 0 -> spurious EOF).
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    return publisher_new(_man_jstr(root, "name"), _man_jstr(root, "key_id"),
                         _man_jstr(root, "homepage"));
}

# manifest_to_jv — build the JSON value object per ADR-0001 (flattened agent
# identity at top level, publisher nested, category as PascalCase, default
# fields always emitted). Returned as a json_v so it can nest (e.g. inside a
# registry index record); mela_manifest_to_json just serializes it.
fn manifest_to_jv(m): i64 {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("name"),        json_v_str_new(man_name(m)));
    json_v_obj_set(o, str_from("version"),     json_v_str_new(man_version(m)));
    json_v_obj_set(o, str_from("description"), json_v_str_new(man_description(m)));

    var p = man_publisher(m);
    var pj = json_v_obj_new();
    json_v_obj_set(pj, str_from("name"),     json_v_str_new(pub_name(p)));
    json_v_obj_set(pj, str_from("key_id"),   json_v_str_new(pub_key_id(p)));
    json_v_obj_set(pj, str_from("homepage"), json_v_str_new(pub_homepage(p)));
    json_v_obj_set(o, str_from("publisher"), pj);

    json_v_obj_set(o, str_from("category"), json_v_str_new(cat_json_name(man_category(m))));
    json_v_obj_set(o, str_from("runtime"),  json_v_str_new(man_runtime(m)));
    json_v_obj_set(o, str_from("screenshots"), _man_arr_from_vec(man_screenshots(m)));
    json_v_obj_set(o, str_from("changelog"),         json_v_str_new(man_changelog(m)));
    json_v_obj_set(o, str_from("min_agnos_version"), json_v_str_new(man_min_agnos_version(m)));

    var dm = man_dependencies(m);
    var deps = json_v_obj_new();
    var dkeys = map_keys(dm);
    var dnk = vec_len(dkeys);
    var di = 0;
    while (di < dnk) {
        var dk = vec_get(dkeys, di);
        json_v_obj_set(deps, dk, json_v_str_new(map_get(dm, dk)));
        di = di + 1;
    }
    json_v_obj_set(o, str_from("dependencies"), deps);
    json_v_obj_set(o, str_from("tags"), _man_arr_from_vec(man_tags(m)));
    return o;
}

# manifest_from_jv — build a MarketplaceManifest from a parsed JSON object value,
# or 0 if it isn't an object. Missing default fields become empty.
fn manifest_from_jv(root): i64 {
    if (json_v_is_obj(root) == 0) { return 0; }

    var name = _man_jstr(root, "name");
    var version = _man_jstr(root, "version");
    var desc = _man_jstr(root, "description");

    var pubv = json_v_obj_get(root, "publisher");
    var publisher = publisher_new(_man_jstr(pubv, "name"), _man_jstr(pubv, "key_id"),
                                  _man_jstr(pubv, "homepage"));

    var catv = json_v_obj_get(root, "category");
    var cat = CAT_PARSE_FAIL;
    if (json_v_is_str(catv) == 1) { cat = cat_json_parse(json_v_str(catv)); }

    var agent = agent_manifest_new(name);
    store64(agent + 8, desc);              # agnostik AgentManifest: description @ 8
    var m = mela_manifest_new(agent, publisher, cat, version);

    man_set_runtime(m, _man_jstr(root, "runtime"));
    man_set_changelog(m, _man_jstr(root, "changelog"));
    man_set_min_agnos_version(m, _man_jstr(root, "min_agnos_version"));

    _man_vec_from_arr(json_v_obj_get(root, "screenshots"), man_screenshots(m));
    _man_vec_from_arr(json_v_obj_get(root, "tags"), man_tags(m));

    var depsv = json_v_obj_get(root, "dependencies");
    if (json_v_is_obj(depsv) == 1) {
        var dm2 = man_dependencies(m);
        var dn = json_v_obj_len(depsv);
        var i = 0;
        while (i < dn) {
            var k = json_v_obj_key(depsv, i);
            var val = json_v_obj_val(depsv, i);
            if (json_v_is_str(val) == 1) { map_set(dm2, k, json_v_str(val)); }
            i = i + 1;
        }
    }
    return m;
}

# mela_manifest_to_json / from_json — serialize per ADR-0001. from_json returns 0 on a
# JSON parse error / non-object root.
fn mela_manifest_to_json(m): Str {
    return json_v_build(manifest_to_jv(m));
}

fn manifest_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));   # see publisher_from_json
    if (root == 0) { return 0; }
    return manifest_from_jv(root);
}

# --- depgraph.cyr ---

# depgraph.cyr — dependency resolution.
#
# Ports the dependency-graph half of rust-old/src/lib.rs: `DepNode` and
# `DependencyGraph` (add / len / is_empty / check_missing / detect_cycle /
# resolve). The graph is a Str-keyed map of name -> DepNode, mirroring the Rust
# `HashMap<String, DepNode>`.
#
# Structs are 8-byte fields via load64/store64; strings are stdlib `Str`.

# ---------------------------------------------------------------------------
# DepNode — { name, version, dependencies }
# ---------------------------------------------------------------------------

fn depnode_new(name: Str, version: Str, deps): i64 {
    var n = alloc(24);
    store64(n,      name);
    store64(n + 8,  version);
    store64(n + 16, deps);     # Vec<Str>
    return n;
}

fn depnode_name(n): Str    { return load64(n); }
fn depnode_version(n): Str { return load64(n + 8); }
fn depnode_deps(n)         { return load64(n + 16); }

# ---------------------------------------------------------------------------
# DependencyGraph — nodes: HashMap<String, DepNode>
# ---------------------------------------------------------------------------
#
# The graph handle IS the Str-keyed node map (no extra wrapper). Use map_new_str
# (not the cstr-keyed map_new) since keys are heap Strs.

fn depgraph_new(): i64 { return map_new_str(); }

# Add a package; keyed by its name (overwrites a same-name node, like
# HashMap::insert). Mirrors Rust `add`.
fn depgraph_add(g, node): i64 {
    map_set(g, depnode_name(node), node);
    return 0;
}

fn depgraph_len(g): i64      { return map_size(g); }
fn depgraph_is_empty(g): i64 { if (map_size(g) == 0) { return 1; } return 0; }
fn depgraph_contains(g, name): i64 { return map_has(g, name); }
fn depgraph_get(g, name): i64      { return map_get(g, name); }

# (owner-name, missing-dep) pair for check_missing results.
fn dep_pair_new(a: Str, b: Str): i64 {
    var p = alloc(16);
    store64(p,     a);
    store64(p + 8, b);
    return p;
}
fn dep_pair_a(p): Str { return load64(p); }
fn dep_pair_b(p): Str { return load64(p + 8); }

# check_missing() — Vec of (node.name, dep) for every dependency not present in
# the graph. Mirrors Rust `check_missing`.
fn depgraph_check_missing(g): i64 {
    var missing = vec_new();
    var nodes = map_values(g);
    var nn = vec_len(nodes);
    var i = 0;
    while (i < nn) {
        var node = vec_get(nodes, i);
        var deps = depnode_deps(node);
        var dn = vec_len(deps);
        var j = 0;
        while (j < dn) {
            var dep = vec_get(deps, j);
            if (map_has(g, dep) == 0) {
                vec_push(missing, dep_pair_new(depnode_name(node), dep));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return missing;
}

# ---------------------------------------------------------------------------
# Cycle detection (DFS) + topological resolve (Kahn)
# ---------------------------------------------------------------------------

# DFS from `name`, carrying the visited set, the recursion-stack set (both
# Str-keyed maps used as sets), and the current path (Vec<Str>). Returns the
# cycle path Vec on a back-edge, else 0. Mirrors rust-old `dfs_cycle`.
fn _dfs_cycle(g, name, visited, onstk, path): i64 {
    var node = map_get(g, name);
    if (node == 0) { return 0; }          # name not in nodes -> None
    map_set(visited, name, 1);
    map_set(onstk, name, 1);
    vec_push(path, name);

    var deps = depnode_deps(node);
    var dn = vec_len(deps);
    var i = 0;
    var result = 0;
    while (i < dn) {
        if (result == 0) {                # stop descending once a cycle is found
            var dep = vec_get(deps, i);
            var dep_node = map_get(g, dep);
            if (dep_node != 0) {
                if (map_has(visited, dep) == 0) {
                    var c = _dfs_cycle(g, dep, visited, onstk, path);
                    if (c != 0) { result = c; }
                } else {
                    if (map_has(onstk, dep) == 1) {   # back-edge -> cycle
                        vec_push(path, dep);
                        result = path;
                    }
                }
            }
        }
        i = i + 1;
    }
    if (result != 0) { return result; }   # early return without popping (Rust parity)
    map_delete(onstk, name);
    vec_pop(path);
    return 0;
}

# detect_cycle() — the cycle path Vec if one exists, else 0. Mirrors rust-old
# `detect_cycle` (`Option<Vec<String>>`; 0 stands in for None).
fn depgraph_detect_cycle(g): i64 {
    var visited = map_new_str();
    var onstk = map_new_str();
    var path = vec_new();
    var names = map_keys(g);
    var nn = vec_len(names);
    var i = 0;
    var result = 0;
    while (i < nn) {
        if (result == 0) {
            var name = vec_get(names, i);
            if (map_has(visited, name) == 0) {
                var c = _dfs_cycle(g, name, visited, onstk, path);
                if (c != 0) { result = c; }
            }
        }
        i = i + 1;
    }
    return result;
}

# Lexicographic (byte-wise) less-than for Strs: 1 if a < b, else 0.
fn _str_lt(a: Str, b: Str): i64 {
    var la = str_len(a);
    var lb = str_len(b);
    var pa = str_data(a);
    var pb = str_data(b);
    var n = la;
    if (lb < la) { n = lb; }
    var i = 0;
    var res = 0;            # 0 undecided, 1 a<b, 2 a>b
    while (i < n) {
        if (res == 0) {
            var ca = load8(pa + i);
            var cb = load8(pb + i);
            if (ca < cb) { res = 1; }
            if (ca > cb) { res = 2; }
        }
        i = i + 1;
    }
    if (res == 1) { return 1; }
    if (res == 2) { return 0; }
    if (la < lb) { return 1; }   # prefix-equal: shorter sorts first
    return 0;
}

# In-place ascending selection sort of a Vec<Str> (no break -> no var-in-loop
# pitfall; node counts are small). Makes the resolve seed order deterministic.
fn _sort_strs(v): i64 {
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        var min_idx = i;
        var j = i + 1;
        while (j < n) {
            if (_str_lt(vec_get(v, j), vec_get(v, min_idx)) == 1) { min_idx = j; }
            j = j + 1;
        }
        var tmp = vec_get(v, i);
        vec_set(v, i, vec_get(v, min_idx));
        vec_set(v, min_idx, tmp);
        i = i + 1;
    }
    return 0;
}

# resolve() — topological install order (Vec<Str>), or 0 if a cycle exists
# (Rust returns Err). Kahn's algorithm: build in-degrees + reverse-deps over the
# edges that exist in the graph, seed with the in-degree-0 nodes (sorted for
# determinism), drain. Mirrors rust-old `resolve`.
fn depgraph_resolve(g): i64 {
    if (depgraph_detect_cycle(g) != 0) { return 0; }    # Err on cycle

    var in_deg = map_new_str();    # name -> in-degree (i64)
    var rev = map_new_str();       # dep  -> Vec<dependent name>
    var nodes = map_values(g);
    var nn = vec_len(nodes);
    var i = 0;
    while (i < nn) {
        var node = vec_get(nodes, i);
        var nm = depnode_name(node);
        if (map_has(in_deg, nm) == 0) { map_set(in_deg, nm, 0); }
        var deps = depnode_deps(node);
        var dn = vec_len(deps);
        var j = 0;
        while (j < dn) {
            var dep = vec_get(deps, j);
            if (map_has(g, dep) == 1) {                  # only edges to known nodes
                if (map_has(in_deg, dep) == 0) { map_set(in_deg, dep, 0); }
                map_set(in_deg, nm, map_get(in_deg, nm) + 1);
                var lst = map_get(rev, dep);
                if (lst == 0) {
                    lst = vec_new();
                    map_set(rev, dep, lst);
                }
                vec_push(lst, nm);
            }
            j = j + 1;
        }
        i = i + 1;
    }

    # seed queue: in-degree-0 names, sorted
    var keys = map_keys(in_deg);
    var kn = vec_len(keys);
    var queue = vec_new();
    var k = 0;
    while (k < kn) {
        var key = vec_get(keys, k);
        if (map_get(in_deg, key) == 0) { vec_push(queue, key); }
        k = k + 1;
    }
    _sort_strs(queue);

    # drain (queue grows via push-back; `head` is the FIFO read cursor)
    var order = vec_new();
    var head = 0;
    while (head < vec_len(queue)) {
        var name = vec_get(queue, head);
        head = head + 1;
        vec_push(order, name);
        var dependents = map_get(rev, name);
        if (dependents != 0) {
            var dd = vec_len(dependents);
            var d = 0;
            while (d < dd) {
                var dependent = vec_get(dependents, d);
                var deg = map_get(in_deg, dependent) - 1;
                map_set(in_deg, dependent, deg);
                if (deg == 0) { vec_push(queue, dependent); }
                d = d + 1;
            }
        }
    }
    return order;
}

# --- trust.cyr ---

# trust.cyr — marketplace trust & signing.
#
# Ports rust-old/src/trust.rs: Ed25519 publisher signing/verification and
# SHA-256 download-integrity hashing, over the `sigil` crypto crate
# (ed25519_keypair / _sign / _verify, sha256_hex, hex_encode / hex_decode).
# Plus the publisher keyring (KeyVersion + PublisherKeyring) — see below.
#
# sigil's constant-time crypto scratch (cbank) calls thread_local_get/set/init.
# The stdlib auto-resolver does NOT pull `thread_local` through sigil's dist
# bundle (only through project source), so without this explicit include the
# binary links with undefined thread_local_* and SIGILLs the first time
# ed25519_verify runs. Force it in here. (Mirrors the libro/kybernet ordering
# note for sigil consumers.)

# Key/signature/digest sizes (bytes). Ed25519 secret = seed(32) || pubkey(32).
var TRUST_SK_LEN  = 64;
var TRUST_PK_LEN  = 32;
var TRUST_SIG_LEN = 64;

# ---------------------------------------------------------------------------
# Hashing + hex
# ---------------------------------------------------------------------------

# SHA-256 of `len` bytes -> 64-char lowercase hex Str. Mirrors Rust `hash_data`.
fn trust_hash_data(data, len): Str {
    return str_from(sha256_hex(data, len));
}

# Hex-encode `len` bytes -> Str. Mirrors Rust `hex::encode`.
fn trust_hex_encode(data, len): Str {
    return str_from(hex_encode(data, len));
}

# Hex-decode a Str -> byte buffer, or 0 on error (odd length / empty / non-hex).
# Mirrors Rust `hex::decode` (odd-length and invalid-digit both Err).
fn trust_hex_decode(s: Str): i64 {
    return hex_decode(str_data(s), str_len(s));
}

# Decoded byte length for a hex Str (len/2). Pairs with trust_hex_decode.
fn trust_hex_decode_len(s: Str): i64 {
    return str_len(s) / 2;
}

# ---------------------------------------------------------------------------
# Signing / verification
# ---------------------------------------------------------------------------

# Sign `len` bytes with a 64-byte Ed25519 secret key (seed||pk). Returns a fresh
# 64-byte signature buffer. Mirrors Rust `sign_data`.
fn trust_sign(sk, data, len): i64 {
    var sig = alloc(TRUST_SIG_LEN);
    ed25519_sign(sk, data, len, sig);
    return sig;
}

# Verify a signature over `len` bytes against a 32-byte public key. Returns 1 if
# valid, 0 otherwise. A signature that is not exactly 64 bytes is rejected
# (Rust `verify_signature` errors on a non-64-byte signature). Mirrors Rust
# `verify_signature` (Ok -> 1, Err -> 0).
fn trust_verify(data, len, sig, sig_len, pk): i64 {
    if (sig_len != TRUST_SIG_LEN) { return 0; }
    return ed25519_verify(pk, data, len, sig);
}

# ---------------------------------------------------------------------------
# Key generation
# ---------------------------------------------------------------------------

# key_id = lowercase hex of the first 8 bytes of the public key (16 chars).
# Mirrors Rust `key_id_from_verifying_key`.
fn trust_key_id_from_pk(pk): Str {
    return str_from(hex_encode(pk, 8));
}

# Deterministic keypair from a 32-byte seed. Fills sk_out[64] and pk_out[32];
# returns the key_id. (Rust generate_keypair is randomized; this is the
# seed-driven form used for known-answer tests + reproducible keys.)
fn trust_keypair_from_seed(seed, sk_out, pk_out): Str {
    ed25519_keypair(seed, sk_out, pk_out);
    return trust_key_id_from_pk(pk_out);
}

# Random keypair. Fills sk_out[64] and pk_out[32]; returns the key_id. Mirrors
# Rust `generate_keypair` (entropy via sigil's CSPRNG).
fn trust_generate_keypair(sk_out, pk_out): Str {
    ed25519_generate_keypair(sk_out, pk_out);
    return trust_key_id_from_pk(pk_out);
}

# ---------------------------------------------------------------------------
# KeyVersion — a versioned publisher key with a validity window
# ---------------------------------------------------------------------------
#
# Rust modelled valid_from / valid_until as chrono DateTime<Utc> with an
# Option for the expiry. The port uses i64 epoch timestamps and an explicit
# has_until flag (Cyrius has no Option), so validity is plain integer
# comparison and tests are deterministic (no Utc::now()).
#
# Layout (8-byte fields):
#   0  key_id          (Str)
#   8  valid_from      (i64 epoch)
#   16 has_until       (i64; 1 if an expiry is set, else 0)
#   24 valid_until     (i64 epoch; meaningful only when has_until == 1)
#   32 public_key_hex  (Str; 64 hex chars for a 32-byte key)

fn kv_new(key_id: Str, valid_from, has_until, valid_until, public_key_hex: Str): i64 {
    var kv = alloc(40);
    store64(kv,      key_id);
    store64(kv + 8,  valid_from);
    store64(kv + 16, has_until);
    store64(kv + 24, valid_until);
    store64(kv + 32, public_key_hex);
    return kv;
}

fn mela_kv_key_id(kv): Str         { return load64(kv); }
fn mela_kv_valid_from(kv): i64     { return load64(kv + 8); }
fn kv_has_until(kv): i64      { return load64(kv + 16); }
fn mela_kv_valid_until(kv): i64    { return load64(kv + 24); }
fn mela_kv_public_key_hex(kv): Str { return load64(kv + 32); }

# is_valid_at(when) — Rust parity: false before valid_from, false after
# valid_until (when set), else true.
fn mela_kv_is_valid_at(kv, when): i64 {
    if (when < mela_kv_valid_from(kv)) { return 0; }
    if (kv_has_until(kv) == 1) {
        if (when > mela_kv_valid_until(kv)) { return 0; }
    }
    return 1;
}

# verifying_key() — decode public_key_hex to 32 raw key bytes, or 0 on error
# (not 64 hex chars, or non-hex). Mirrors Rust `verifying_key` (hex-decode then
# require exactly 32 bytes).
fn kv_verifying_key(kv): i64 {
    var hexs = mela_kv_public_key_hex(kv);
    if (str_len(hexs) != 64) { return 0; }      # must be a 32-byte key
    return hex_decode(str_data(hexs), str_len(hexs));   # 0 on non-hex digit
}

# ---------------------------------------------------------------------------
# PublisherKeyring — trusted publisher keys, key_id -> [KeyVersion]
# ---------------------------------------------------------------------------
#
# Str-keyed map of key_id -> Vec<KeyVersion>. The disk loader (Rust `load()` —
# scans a directory of JSON key files) is `keyring_load_dir`, below.
# get_current_key takes an explicit `now` (Rust used Utc::now() implicitly) for
# deterministic trust decisions.

fn mela_keyring_new(): i64 { return map_new_str(); }

# add_key — append a KeyVersion under its key_id (Rust `add_key`).
fn mela_keyring_add_key(kr, kv): i64 {
    var kid = mela_kv_key_id(kv);
    var list = map_get(kr, kid);
    if (list == 0) {
        list = vec_new();
        map_set(kr, kid, list);
    }
    vec_push(list, kv);
    return 0;
}

# get_current_key(key_id, now) — first KeyVersion valid at `now`, or 0
# (Rust `get_current_key`).
fn keyring_get_current_key(kr, key_id, now): i64 {
    var list = map_get(kr, key_id);
    if (list == 0) { return 0; }
    var n = vec_len(list);
    var i = 0;
    var found = 0;
    while (i < n) {
        if (found == 0) {
            var kv = vec_get(list, i);
            if (mela_kv_is_valid_at(kv, now) == 1) { found = kv; }
        }
        i = i + 1;
    }
    return found;
}

# get_all_versions(key_id) — every KeyVersion (incl. expired), or an empty Vec
# (Rust `get_all_versions`).
fn mela_keyring_get_all_versions(kr, key_id): i64 {
    var list = map_get(kr, key_id);
    if (list == 0) { return vec_new(); }
    return list;
}

fn mela_keyring_len(kr): i64      { return map_size(kr); }
fn mela_keyring_is_empty(kr): i64 { if (map_size(kr) == 0) { return 1; } return 0; }

# ---------------------------------------------------------------------------
# KeyVersion JSON + keyring disk loader (resolves the ADR-0003 deferral)
# ---------------------------------------------------------------------------

var KEYRING_MAXLEN = 1048576;     # 1 MiB read buffer per key file

fn _kv_jstr(o, key): Str {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}
fn _kv_jint(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_int(v) == 0) { return 0; }
    return json_v_int(v);
}

fn kv_to_jv(kv): i64 {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("key_id"),         json_v_str_new(mela_kv_key_id(kv)));
    json_v_obj_set(o, str_from("valid_from"),     json_v_int_new(mela_kv_valid_from(kv)));
    json_v_obj_set(o, str_from("has_until"),      json_v_int_new(kv_has_until(kv)));
    json_v_obj_set(o, str_from("valid_until"),    json_v_int_new(mela_kv_valid_until(kv)));
    json_v_obj_set(o, str_from("public_key_hex"), json_v_str_new(mela_kv_public_key_hex(kv)));
    return o;
}
fn kv_from_jv(o): i64 {
    if (json_v_is_obj(o) == 0) { return 0; }
    return kv_new(_kv_jstr(o, "key_id"), _kv_jint(o, "valid_from"), _kv_jint(o, "has_until"),
                  _kv_jint(o, "valid_until"), _kv_jstr(o, "public_key_hex"));
}
fn kv_to_json(kv): Str { return json_v_build(kv_to_jv(kv)); }
fn kv_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    return kv_from_jv(root);
}

# True if the filename ends in ".json".
fn _ends_dot_json(nm: Str): i64 {
    var n = str_len(nm);
    if (n < 5) { return 0; }
    return str_eq_cstr(str_sub(nm, n - 5, 5), ".json");
}

# keyring_load_dir(kr, dir) — load every `*.json` key file in `dir`, each a JSON
# ARRAY of KeyVersion objects, into the keyring. Returns the count added (0 if
# the dir is absent). Mirrors Rust `PublisherKeyring::load` (resolves ADR-0003).
fn keyring_load_dir(kr, dir: Str): i64 {
    if (is_dir(dir) == 0) { return 0; }
    var entries = dir_list(dir);
    var n = vec_len(entries);
    var i = 0;
    var count = 0;
    while (i < n) {
        var nm = vec_get(entries, i);
        if (_ends_dot_json(nm) == 1) {
            var full = path_join(dir, nm);
            var buf = alloc(KEYRING_MAXLEN);
            var rn = file_read_all(str_data(full), buf, KEYRING_MAXLEN);
            if (rn > 0) {
                var root = json_v_parse_str(buf, rn);
                if (root != 0) {
                    if (json_v_is_arr(root) == 1) {
                        var an = json_v_arr_len(root);
                        var j = 0;
                        while (j < an) {
                            var kv = kv_from_jv(json_v_arr_get(root, j));
                            if (kv != 0) { mela_keyring_add_key(kr, kv); count = count + 1; }
                            j = j + 1;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    return count;
}

# --- transparency.cyr ---

# transparency.cyr — append-only, hash-chained publication log.
#
# Ports rust-old/src/transparency.rs: each LogEntry is SHA-256 hash-chained to
# the previous one, so a silent edit anywhere breaks the chain (cf. certificate
# transparency / Go's sum database). Hashing is via sigil (reused through
# trust_hash_data); the JSON codec rides bayan (ADR-0001).
#
# timestamp is an i64 epoch, not chrono DateTime — explicit at append() and
# hashed/serialized as the epoch (ADR-0004), consistent with the trust gate
# (ADR-0003). The Rust entry_hash preimage used timestamp.to_rfc3339(); the port
# uses the epoch's decimal form. The chain is self-consistent (mela computes and
# verifies both sides); there is no cross-language entry-hash vector to match.

# ---------------------------------------------------------------------------
# LogEntry
# ---------------------------------------------------------------------------
#
# Layout (8-byte fields):
#   0  sequence          (i64, 0-indexed)
#   8  timestamp         (i64 epoch)
#   16 package           (Str; publisher/name)
#   24 version           (Str)
#   32 publisher_key_id  (Str)
#   40 content_hash      (Str; SHA-256 hex of package content)
#   48 signature_hash    (Str; SHA-256 hex of the signature)
#   56 previous_hash     (Str; "" for entry 0)
#   64 entry_hash        (Str; SHA-256 hex over fields 0..56)

fn log_entry_new(sequence, timestamp, package: Str, version: Str, key_id: Str,
                 content_hash: Str, signature_hash: Str, previous_hash: Str,
                 entry_hash: Str): i64 {
    var e = alloc(72);
    store64(e,      sequence);
    store64(e + 8,  timestamp);
    store64(e + 16, package);
    store64(e + 24, version);
    store64(e + 32, key_id);
    store64(e + 40, content_hash);
    store64(e + 48, signature_hash);
    store64(e + 56, previous_hash);
    store64(e + 64, entry_hash);
    return e;
}

fn log_seq(e): i64               { return load64(e); }
fn log_timestamp(e): i64         { return load64(e + 8); }
fn log_package(e): Str           { return load64(e + 16); }
fn log_version(e): Str           { return load64(e + 24); }
fn log_key_id(e): Str            { return load64(e + 32); }
fn log_content_hash(e): Str      { return load64(e + 40); }
fn log_signature_hash(e): Str    { return load64(e + 48); }
fn log_previous_hash(e): Str     { return load64(e + 56); }
fn log_entry_hash(e): Str        { return load64(e + 64); }
fn log_set_entry_hash(e, h: Str) { store64(e + 64, h); return 0; }

# Write i64 `n` as 8 big-endian bytes to `out` (Rust: sequence.to_be_bytes()).
fn _be64(n, out): i64 {
    var i = 0;
    while (i < 8) {
        store8(out + i, (n >> ((7 - i) * 8)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# memcpy `s`'s bytes into buf+off; return the new offset.
fn _append_str(buf, off, s: Str): i64 {
    memcpy(buf + off, str_data(s), str_len(s));
    return off + str_len(s);
}

# compute_hash() — SHA-256 hex over sequence(BE8) || timestamp(decimal) ||
# package || version || publisher_key_id || content_hash || signature_hash ||
# previous_hash. Excludes entry_hash itself. Mirrors Rust `compute_hash` (with
# the ADR-0004 timestamp representation).
fn log_entry_compute_hash(e): Str {
    var ts = str_from_int(log_timestamp(e));
    var pkg = log_package(e);
    var ver = log_version(e);
    var kid = log_key_id(e);
    var ch  = log_content_hash(e);
    var sh  = log_signature_hash(e);
    var ph  = log_previous_hash(e);

    var total = 8 + str_len(ts) + str_len(pkg) + str_len(ver) + str_len(kid)
              + str_len(ch) + str_len(sh) + str_len(ph);
    var buf = alloc(total);
    _be64(log_seq(e), buf);
    var off = 8;
    off = _append_str(buf, off, ts);
    off = _append_str(buf, off, pkg);
    off = _append_str(buf, off, ver);
    off = _append_str(buf, off, kid);
    off = _append_str(buf, off, ch);
    off = _append_str(buf, off, sh);
    off = _append_str(buf, off, ph);
    return trust_hash_data(buf, total);
}

# verify_self() — entry_hash matches the recomputed hash. Mirrors Rust.
fn log_entry_verify_self(e): i64 {
    return str_eq(log_entry_hash(e), log_entry_compute_hash(e));
}

# ---------------------------------------------------------------------------
# TransparencyLog — a Vec<LogEntry>
# ---------------------------------------------------------------------------

fn tlog_new(): i64 { return vec_new(); }

# append() — add an entry: sequence = current len, previous_hash = last entry's
# entry_hash (or ""), entry_hash = compute_hash. Returns the new entry. Takes an
# explicit `timestamp` (Rust used Utc::now()) — ADR-0004. Mirrors Rust `append`.
fn tlog_append(log, package: Str, version: Str, key_id: Str,
               content_hash: Str, signature_hash: Str, timestamp): i64 {
    var seq = vec_len(log);
    var prev = str_from("");
    if (seq > 0) { prev = log_entry_hash(vec_get(log, seq - 1)); }
    var e = log_entry_new(seq, timestamp, package, version, key_id,
                          content_hash, signature_hash, prev, str_from(""));
    log_set_entry_hash(e, log_entry_compute_hash(e));
    vec_push(log, e);
    return e;
}

# verify_chain() — 1 if every entry self-verifies, links to its predecessor, and
# carries the right sequence; 0 otherwise. Mirrors Rust `verify_chain` (Ok->1,
# Err->0).
fn tlog_verify_chain(log): i64 {
    var n = vec_len(log);
    var i = 0;
    var ok = 1;
    while (i < n) {
        if (ok == 1) {
            var e = vec_get(log, i);
            if (log_entry_verify_self(e) == 0) { ok = 0; }
            else {
                if (i == 0) {
                    if (str_len(log_previous_hash(e)) != 0) { ok = 0; }
                } else {
                    var prev = vec_get(log, i - 1);
                    if (str_eq(log_previous_hash(e), log_entry_hash(prev)) == 0) { ok = 0; }
                }
                if (log_seq(e) != i) { ok = 0; }
            }
        }
        i = i + 1;
    }
    return ok;
}

# find(package, version) — first matching entry, or 0. Mirrors Rust `find`.
fn tlog_find(log, package: Str, version: Str): i64 {
    var n = vec_len(log);
    var i = 0;
    var found = 0;
    while (i < n) {
        if (found == 0) {
            var e = vec_get(log, i);
            if (str_eq(log_package(e), package) == 1) {
                if (str_eq(log_version(e), version) == 1) { found = e; }
            }
        }
        i = i + 1;
    }
    return found;
}

# entries_for_package(package) — Vec of every entry for the package. Mirrors Rust.
fn tlog_entries_for_package(log, package: Str): i64 {
    var out = vec_new();
    var n = vec_len(log);
    var i = 0;
    while (i < n) {
        var e = vec_get(log, i);
        if (str_eq(log_package(e), package) == 1) { vec_push(out, e); }
        i = i + 1;
    }
    return out;
}

# latest() — last entry, or 0. Mirrors Rust `latest`.
fn tlog_latest(log): i64 {
    var n = vec_len(log);
    if (n == 0) { return 0; }
    return vec_get(log, n - 1);
}

fn tlog_len(log): i64      { return vec_len(log); }
fn tlog_is_empty(log): i64 { if (vec_len(log) == 0) { return 1; } return 0; }

# ---------------------------------------------------------------------------
# JSON codec (wire format per ADR-0001; timestamp as int epoch per ADR-0004)
# ---------------------------------------------------------------------------

# String value of object field `key`, or "" if absent / not a string.
fn _log_jstr(obj, key): Str {
    var v = json_v_obj_get(obj, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}

# Integer value of object field `key`, or 0 if absent / not an integer.
fn _log_jint(obj, key): i64 {
    var v = json_v_obj_get(obj, key);
    if (v == 0) { return 0; }
    if (json_v_is_int(v) == 0) { return 0; }
    return json_v_int(v);
}

fn _log_entry_to_jv(e): i64 {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("sequence"),         json_v_int_new(log_seq(e)));
    json_v_obj_set(o, str_from("timestamp"),        json_v_int_new(log_timestamp(e)));
    json_v_obj_set(o, str_from("package"),          json_v_str_new(log_package(e)));
    json_v_obj_set(o, str_from("version"),          json_v_str_new(log_version(e)));
    json_v_obj_set(o, str_from("publisher_key_id"), json_v_str_new(log_key_id(e)));
    json_v_obj_set(o, str_from("content_hash"),     json_v_str_new(log_content_hash(e)));
    json_v_obj_set(o, str_from("signature_hash"),   json_v_str_new(log_signature_hash(e)));
    json_v_obj_set(o, str_from("previous_hash"),    json_v_str_new(log_previous_hash(e)));
    json_v_obj_set(o, str_from("entry_hash"),       json_v_str_new(log_entry_hash(e)));
    return o;
}

# to_json() — the log as a JSON array of entry objects. Mirrors Rust `to_json`.
fn tlog_to_json(log): Str {
    var arr = json_v_arr_new();
    var n = vec_len(log);
    var i = 0;
    while (i < n) {
        json_v_arr_push(arr, _log_entry_to_jv(vec_get(log, i)));
        i = i + 1;
    }
    return json_v_build(arr);
}

# from_json() — rebuild a log from JSON, then verify the chain. Returns 0 on a
# JSON parse error, a non-array root, OR a chain that fails verification (a
# tampered entry, like the Rust `from_json` which calls verify_chain). Mirrors
# Rust `from_json`.
fn tlog_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));   # explicit buf+len (see trust.cyr)
    if (root == 0) { return 0; }
    if (json_v_is_arr(root) == 0) { return 0; }
    var log = tlog_new();
    var n = json_v_arr_len(root);
    var i = 0;
    while (i < n) {
        var o = json_v_arr_get(root, i);
        var e = log_entry_new(
            _log_jint(o, "sequence"),
            _log_jint(o, "timestamp"),
            _log_jstr(o, "package"),
            _log_jstr(o, "version"),
            _log_jstr(o, "publisher_key_id"),
            _log_jstr(o, "content_hash"),
            _log_jstr(o, "signature_hash"),
            _log_jstr(o, "previous_hash"),
            _log_jstr(o, "entry_hash"));
        vec_push(log, e);
        i = i + 1;
    }
    if (tlog_verify_chain(log) == 0) { return 0; }
    return log;
}

# --- local_registry.cyr ---

# local_registry.cyr — file-backed registry of installed packages.
#
# Ports rust-old/src/local_registry.rs: the on-device index of installed
# marketplace packages (install / record / query / search / remove), persisted
# to `index.json` under the registry root. Hashing + signature verification ride
# the trust gate (v0.3.0); the manifest model (v0.2.0) is the record payload.
#
# The registry holds the on-disk index; install records a (validated) manifest +
# content hash + size and persists it. Tarball extraction (ADR-0005) is
# IMPLEMENTED — `agpkg_extract_to_dir` unpacks the bundle to the install dir, run
# by `pipeline_install` after both trust gates pass (signature via
# `registry_verify_package` + SHA-256 digest). timestamps are i64 epochs supplied
# explicitly (ADR-0003/0004 precedent).

var REG_INDEX_FILENAME = "index.json";
var REG_INDEX_MAXLEN   = 1048576;        # 1 MiB read buffer for the index
var REG_DIR_MODE       = 0x1FF;          # 0o777

# ---------------------------------------------------------------------------
# InstalledMarketplacePackage record
# ---------------------------------------------------------------------------
#
# Layout (8-byte fields):
#   0  manifest        (MarketplaceManifest*)
#   8  installed_at    (i64 epoch)
#   16 install_dir     (Str)
#   24 package_hash    (Str; SHA-256 hex of the package)
#   32 auto_update     (i64; 0/1)
#   40 installed_size  (i64 bytes)

fn imp_new(manifest, installed_at, install_dir: Str, package_hash: Str,
           auto_update, installed_size): i64 {
    var p = alloc(48);
    store64(p,      manifest);
    store64(p + 8,  installed_at);
    store64(p + 16, install_dir);
    store64(p + 24, package_hash);
    store64(p + 32, auto_update);
    store64(p + 40, installed_size);
    return p;
}

fn imp_manifest(p)            { return load64(p); }
fn imp_installed_at(p): i64   { return load64(p + 8); }
fn imp_install_dir(p): Str    { return load64(p + 16); }
fn imp_package_hash(p): Str   { return load64(p + 24); }
fn imp_auto_update(p): i64    { return load64(p + 32); }
fn imp_installed_size(p): i64 { return load64(p + 40); }

# Shorthands off the manifest (Rust name() / version() / publisher()).
fn imp_name(p): Str      { return man_name(imp_manifest(p)); }
fn imp_version(p): Str   { return man_version(imp_manifest(p)); }
fn imp_publisher(p): Str { return pub_name(man_publisher(imp_manifest(p))); }

# ---------------------------------------------------------------------------
# Install result
# ---------------------------------------------------------------------------
#
#   0 name (Str)  8 version (Str)  16 install_dir (Str)
#   24 has_upgrade (i64)  32 upgraded_from (Str; valid when has_upgrade==1)

fn instres_name(x): Str          { return load64(x); }
fn instres_version(x): Str       { return load64(x + 8); }
fn instres_install_dir(x): Str   { return load64(x + 16); }
fn instres_has_upgrade(x): i64   { return load64(x + 24); }
fn instres_upgraded_from(x): Str { return load64(x + 32); }

# ---------------------------------------------------------------------------
# Index JSON codec (on-disk format pinned in ADR-0005)
# ---------------------------------------------------------------------------

fn _reg_jstr(o, key): Str {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}
fn _reg_jint(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_int(v) == 0) { return 0; }
    return json_v_int(v);
}
fn _reg_jbool(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_bool(v) == 0) { return 0; }
    return json_v_bool(v);
}

fn _reg_record_to_jv(p): i64 {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("manifest"),       manifest_to_jv(imp_manifest(p)));
    json_v_obj_set(o, str_from("installed_at"),   json_v_int_new(imp_installed_at(p)));
    json_v_obj_set(o, str_from("install_dir"),    json_v_str_new(imp_install_dir(p)));
    json_v_obj_set(o, str_from("package_hash"),   json_v_str_new(imp_package_hash(p)));
    json_v_obj_set(o, str_from("auto_update"),    json_v_bool_new(imp_auto_update(p)));
    json_v_obj_set(o, str_from("installed_size"), json_v_int_new(imp_installed_size(p)));
    return o;
}

fn _reg_record_from_jv(o): i64 {
    if (json_v_is_obj(o) == 0) { return 0; }
    var manifest = manifest_from_jv(json_v_obj_get(o, "manifest"));
    if (manifest == 0) { return 0; }
    return imp_new(manifest, _reg_jint(o, "installed_at"), _reg_jstr(o, "install_dir"),
                   _reg_jstr(o, "package_hash"), _reg_jbool(o, "auto_update"),
                   _reg_jint(o, "installed_size"));
}

# Serialize an index map (name -> record) to a JSON object string.
fn registry_index_to_json(index): Str {
    var o = json_v_obj_new();
    var keys = map_keys(index);
    var n = vec_len(keys);
    var i = 0;
    while (i < n) {
        var k = vec_get(keys, i);
        json_v_obj_set(o, k, _reg_record_to_jv(map_get(index, k)));
        i = i + 1;
    }
    return json_v_build(o);
}

# Parse a JSON index object string into `index`. Returns 1 on success, 0 on a
# parse error / non-object root (entries that fail to rebuild are skipped).
fn registry_index_from_json_into(js: Str, index): i64 {
    var root = json_v_parse_str(str_data(js), str_len(js));   # explicit buf+len (see trust.cyr)
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    var n = json_v_obj_len(root);
    var i = 0;
    while (i < n) {
        var key = json_v_obj_key(root, i);
        var rec = _reg_record_from_jv(json_v_obj_val(root, i));
        if (rec != 0) { map_set(index, key, rec); }
        i = i + 1;
    }
    return 1;
}

# ---------------------------------------------------------------------------
# LocalRegistry
# ---------------------------------------------------------------------------
#
# Layout (8-byte fields):
#   0  root_dir          (Str)
#   8  index             (Str-keyed map: name -> record)
#   16 keyring           (PublisherKeyring, from trust)
#   24 transparency_log  (TransparencyLog)
#   32 storage_quota     (i64; 0 = unlimited)

fn registry_root(r): Str   { return load64(r); }
fn registry_index(r)       { return load64(r + 8); }
fn registry_keyring(r)     { return load64(r + 16); }
fn registry_tlog(r)        { return load64(r + 24); }
fn registry_quota(r): i64  { return load64(r + 32); }
fn registry_set_storage_quota(r, q) { store64(r + 32, q); return 0; }

fn _registry_index_path(r): Str {
    return path_join(registry_root(r), str_from(REG_INDEX_FILENAME));
}

# Save the index to <root>/index.json (creates root if needed). Returns bytes
# written, or a negative error. Mirrors Rust `save_index`.
fn registry_save_index(r): i64 {
    sys_mkdir(str_data(registry_root(r)), REG_DIR_MODE);   # ok if it already exists
    var js = registry_index_to_json(registry_index(r));
    return file_write_all(str_data(_registry_index_path(r)), str_data(js), str_len(js));
}

# Load the index from disk into the registry (no-op if the file is absent).
# Mirrors Rust `load_index`.
fn registry_load_index(r): i64 {
    var path = _registry_index_path(r);
    if (file_exists(str_data(path)) == 0) { return 0; }
    var buf = alloc(REG_INDEX_MAXLEN);
    var n = file_read_all(str_data(path), buf, REG_INDEX_MAXLEN);
    if (n <= 0) { return 0; }
    return registry_index_from_json_into(str_new(buf, n), registry_index(r));
}

# new(root_dir) — file-backed registry; loads any existing index. Mirrors Rust `new`.
fn mela_registry_new(root_dir: Str): i64 {
    var r = alloc(40);
    store64(r,      root_dir);
    store64(r + 8,  map_new_str());
    store64(r + 16, mela_keyring_new());
    store64(r + 24, tlog_new());
    store64(r + 32, 0);
    registry_load_index(r);
    return r;
}

# in_memory() — no persistence (root "/dev/null"). Mirrors Rust `in_memory`.
fn registry_in_memory(): i64 {
    var r = alloc(40);
    store64(r,      str_from("/dev/null"));
    store64(r + 8,  map_new_str());
    store64(r + 16, mela_keyring_new());
    store64(r + 24, tlog_new());
    store64(r + 32, 0);
    return r;
}

fn registry_len(r): i64      { return map_size(registry_index(r)); }
fn registry_is_empty(r): i64 { if (map_size(registry_index(r)) == 0) { return 1; } return 0; }
fn registry_get_package(r, name: Str): i64 { return map_get(registry_index(r), name); }

# total_installed_size — sum of installed_size across the index. Mirrors Rust.
fn registry_total_installed_size(r): i64 {
    var vals = map_values(registry_index(r));
    var n = vec_len(vals);
    var i = 0;
    var total = 0;
    while (i < n) {
        total = total + imp_installed_size(vec_get(vals, i));
        i = i + 1;
    }
    return total;
}

fn registry_packages_dir(r): Str {
    return path_join(registry_root(r), str_from("packages"));
}

# install — record an (already-extracted) package: quota check, manifest
# validate, upgrade detection, index insert, persist. Returns an install-result,
# or 0 on a quota or validation failure. Mirrors Rust `install_package` minus the
# tarball extraction (ADR-0005). auto_update defaults to 0, as in Rust.
fn registry_install(r, manifest, package_hash: Str, installed_size, installed_at): i64 {
    var quota = registry_quota(r);
    if (quota > 0) {
        if (registry_total_installed_size(r) + installed_size > quota) { return 0; }
    }
    if (vec_len(manifest_validate(manifest)) != 0) { return 0; }

    var name = man_name(manifest);
    var version = man_version(manifest);

    var has_up = 0;
    var up_from = str_from("");
    var existing = map_get(registry_index(r), name);
    if (existing != 0) {
        has_up = 1;
        up_from = imp_version(existing);
    }

    var install_dir = path_join(registry_packages_dir(r), name);
    var rec = imp_new(manifest, installed_at, install_dir, package_hash, 0, installed_size);
    map_set(registry_index(r), name, rec);
    registry_save_index(r);

    var res = alloc(40);
    store64(res,      name);
    store64(res + 8,  version);
    store64(res + 16, install_dir);
    store64(res + 24, has_up);
    store64(res + 32, up_from);
    return res;
}

# Recursively delete a directory tree (files via unlink, dirs via rmdir after
# their contents). Returns the number of files removed. Mirrors Rust
# count_files + remove_dir_all on uninstall.
fn _rmtree(dir: Str): i64 {
    var entries = dir_list(dir);
    var n = vec_len(entries);
    var i = 0;
    var count = 0;
    while (i < n) {
        var full = path_join(dir, vec_get(entries, i));
        if (is_dir(full) == 1) { count = count + _rmtree(full); }
        else { sys_unlink(str_data(full)); count = count + 1; }
        i = i + 1;
    }
    sys_rmdir(str_data(dir));
    return count;
}

# uninstall(name) — remove the package's extracted files from disk, drop it from
# the index, and persist. Returns 1 if removed, 0 if not installed (Rust errors
# in that case). Mirrors Rust `uninstall_package` (now incl. remove_dir_all).
fn registry_uninstall(r, name: Str): i64 {
    var rec = map_get(registry_index(r), name);
    if (rec == 0) { return 0; }
    var dir = imp_install_dir(rec);
    if (is_dir(dir) == 1) { _rmtree(dir); }     # remove the extracted files
    map_delete(registry_index(r), name);
    registry_save_index(r);
    return 1;
}

# list_installed — all records, sorted by name. Mirrors Rust `list_installed`.
fn registry_list_installed(r): i64 {
    var vals = map_values(registry_index(r));
    var n = vec_len(vals);
    # selection sort by imp_name (reuses _str_lt from depgraph.cyr)
    var i = 0;
    while (i < n) {
        var min_idx = i;
        var j = i + 1;
        while (j < n) {
            if (_str_lt(imp_name(vec_get(vals, j)), imp_name(vec_get(vals, min_idx))) == 1) { min_idx = j; }
            j = j + 1;
        }
        var tmp = vec_get(vals, i);
        vec_set(vals, i, vec_get(vals, min_idx));
        vec_set(vals, min_idx, tmp);
        i = i + 1;
    }
    return vals;
}

# ASCII-lowercase a Str into a fresh Str (for case-insensitive search).
fn _reg_to_lower(s: Str): Str {
    var n = str_len(s);
    var src = str_data(s);
    var buf = alloc(n + 1);
    var i = 0;
    while (i < n) {
        var c = load8(src + i);
        if (c >= 65) { if (c <= 90) { c = c + 32; } }
        store8(buf + i, c);
        i = i + 1;
    }
    store8(buf + n, 0);
    return str_new(buf, n);
}

# True if record matches a lowercased query in name, description, or any tag.
fn _reg_matches(rec, ql: Str): i64 {
    if (str_contains(_reg_to_lower(imp_name(rec)), ql) == 1) { return 1; }
    if (str_contains(_reg_to_lower(man_description(imp_manifest(rec))), ql) == 1) { return 1; }
    var tags = man_tags(imp_manifest(rec));
    var n = vec_len(tags);
    var i = 0;
    var hit = 0;
    while (i < n) {
        if (hit == 0) {
            if (str_contains(_reg_to_lower(vec_get(tags, i)), ql) == 1) { hit = 1; }
        }
        i = i + 1;
    }
    return hit;
}

# search(query) — case-insensitive match on name / description / tags. Mirrors
# Rust `search`.
fn mela_registry_search(r, query: Str): i64 {
    var ql = _reg_to_lower(query);
    var vals = map_values(registry_index(r));
    var n = vec_len(vals);
    var out = vec_new();
    var i = 0;
    while (i < n) {
        var rec = vec_get(vals, i);
        if (_reg_matches(rec, ql) == 1) { vec_push(out, rec); }
        i = i + 1;
    }
    return out;
}

# verify a package's signature against a trusted publisher key. Returns 1 if a
# current key for `key_id` exists and the signature over `content` is valid; 0
# otherwise (no trusted key, undecodable key, or bad signature). This is the
# trust gate the registry enforces at install — mirrors the Rust
# install_package verification branch (get_current_key -> verifying_key ->
# verify_signature). `now` is explicit (ADR-0003).
fn registry_verify_package(keyring, key_id: Str, content, content_len, sig, sig_len, now): i64 {
    var kv = keyring_get_current_key(keyring, key_id, now);
    if (kv == 0) { return 0; }              # no trusted key for this publisher
    var pk = kv_verifying_key(kv);
    if (pk == 0) { return 0; }              # undecodable public key
    return trust_verify(content, content_len, sig, sig_len, pk);
}

# --- remote_client.cyr ---

# remote_client.cyr — client for a remote marketplace registry.
#
# Ports rust-old/src/remote_client.rs: the request/response logic for the four
# registry flows — search, fetch-manifest, download, publish (+ check-updates) —
# plus URL building, percent-encoding, path-segment validation, the response
# types, and the on-disk response cache.
#
# Transport is REAL (ADR-0006, v0.9.2/0.9.3): the four flows run over `sandhi`'s
# HTTP/HTTPS client (DNS + TLS). `rc_search` / `rc_fetch_manifest` fetch + parse +
# cache; `rc_download` fetches the package and writes it to the cache; `rc_publish`
# POSTs the bundle (Bearer auth) and parses the PublishResponse; `rc_check_updates`
# diffs each installed package against its latest manifest. URL building, percent-
# encoding, path-segment validation, response (de)serialization, and the on-disk
# cache are all parity-tested; parsers are fuzzed; the live fetch is demoed.

var DEFAULT_REGISTRY_URL = "https://registry.agnos.org";
var REQUEST_TIMEOUT_SECS  = 30;
var DOWNLOAD_TIMEOUT_SECS  = 300;

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Percent-encode a Str for a URL query parameter. Unreserved bytes
# (A-Z a-z 0-9 - _ . ~) pass through; everything else becomes %XX (uppercase
# hex), byte-wise — so multibyte UTF-8 encodes per-byte. Mirrors Rust `url_encode`.
fn url_encode(s: Str): Str {
    var n = str_len(s);
    var src = str_data(s);
    var sb = str_builder_new();
    var i = 0;
    while (i < n) {
        var c = load8(src + i) & 0xFF;
        var unreserved = 0;
        if (c >= 65) { if (c <= 90) { unreserved = 1; } }    # A-Z
        if (c >= 97) { if (c <= 122) { unreserved = 1; } }   # a-z
        if (c >= 48) { if (c <= 57) { unreserved = 1; } }    # 0-9
        if (c == 45) { unreserved = 1; }                      # -
        if (c == 95) { unreserved = 1; }                      # _
        if (c == 46) { unreserved = 1; }                      # .
        if (c == 126) { unreserved = 1; }                     # ~
        if (unreserved == 1) {
            var ch[2];
            store8(&ch, c);
            store8(&ch + 1, 0);
            str_builder_add_cstr(sb, &ch);
        } else {
            var pct[4];
            store8(&pct, 37);                                 # '%'
            store8(&pct + 1, _hex_digit_upper(c >> 4));
            store8(&pct + 2, _hex_digit_upper(c & 15));
            store8(&pct + 3, 0);
            str_builder_add_cstr(sb, &pct);
        }
        i = i + 1;
    }
    return str_builder_build(sb);
}

# Nibble (0..15) -> uppercase hex ASCII byte.
fn _hex_digit_upper(v): i64 {
    if (v < 10) { return 48 + v; }     # '0'..'9'
    return 55 + v;                     # 'A'..'F'  (65 + v-10)
}

# Replace any byte that isn't ASCII-alphanumeric / '-' / '_' with '_'. Mirrors
# Rust `sanitize_filename` (ASCII subset; no oracle case is non-ASCII).
fn sanitize_filename(s: Str): Str {
    var n = str_len(s);
    var src = str_data(s);
    var buf = alloc(n + 1);
    var i = 0;
    while (i < n) {
        var c = load8(src + i) & 0xFF;
        var keep = 0;
        if (c >= 65) { if (c <= 90) { keep = 1; } }
        if (c >= 97) { if (c <= 122) { keep = 1; } }
        if (c >= 48) { if (c <= 57) { keep = 1; } }
        if (c == 45) { keep = 1; }
        if (c == 95) { keep = 1; }
        if (keep == 1) { store8(buf + i, c); }
        else { store8(buf + i, 95); }     # '_'
        i = i + 1;
    }
    store8(buf + n, 0);
    return str_new(buf, n);
}

# Validate a name/version path segment: 1 if safe, 0 if empty or it contains
# '/', '\', "..", or NUL. Mirrors Rust `validate_path_segment`.
fn validate_path_segment(value: Str): i64 {
    var n = str_len(value);
    if (n == 0) { return 0; }
    var d = str_data(value);
    var i = 0;
    var bad = 0;
    while (i < n) {
        var c = load8(d + i) & 0xFF;
        if (c == 47) { bad = 1; }     # '/'
        if (c == 92) { bad = 1; }     # '\'
        if (c == 0)  { bad = 1; }     # NUL
        if (c == 46) {                # '.', check for ".."
            if (i + 1 < n) {
                if ((load8(d + i + 1) & 0xFF) == 46) { bad = 1; }
            }
        }
        i = i + 1;
    }
    if (bad == 1) { return 0; }
    return 1;
}

# ---------------------------------------------------------------------------
# URL builders
# ---------------------------------------------------------------------------

# GET {base}/v1/packages/search?q={enc}[&category={enc}]&page={n}
fn build_search_url(base: Str, query: Str, category: Str, has_category, page): Str {
    var u = str_cat(str_cat(base, str_from("/v1/packages/search?q=")), url_encode(query));
    if (has_category == 1) {
        u = str_cat(str_cat(u, str_from("&category=")), url_encode(category));
    }
    return str_cat(str_cat(u, str_from("&page=")), str_from_int(page));
}

# {base}/v1/packages/{name}/{version}
fn build_manifest_url(base: Str, name: Str, version: Str): Str {
    var u = str_cat(base, str_from("/v1/packages/"));
    u = str_cat(u, name);
    u = str_cat(u, str_from("/"));
    return str_cat(u, version);
}

# {base}/v1/packages/{name}/{version}/download
fn build_download_url(base: Str, name: Str, version: Str): Str {
    return str_cat(build_manifest_url(base, name, version), str_from("/download"));
}

# {base}/v1/packages/publish
fn build_publish_url(base: Str): Str {
    return str_cat(base, str_from("/v1/packages/publish"));
}

# {base}/v1/packages/{name}/latest
fn build_latest_url(base: Str, name: Str): Str {
    return str_cat(str_cat(base, str_from("/v1/packages/")), str_cat(name, str_from("/latest")));
}

# ---------------------------------------------------------------------------
# Response types + JSON codec (response-parse parity; ADR-0001 wire style)
# ---------------------------------------------------------------------------

fn _rc_jstr(o, key): Str {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}
fn _rc_jint(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_int(v) == 0) { return 0; }
    return json_v_int(v);
}
fn _rc_jbool(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_bool(v) == 0) { return 0; }
    return json_v_bool(v);
}

# --- SearchResult { qualified_name, latest_version, description, downloads, category, publisher }
fn sresult_new(qualified_name: Str, latest_version: Str, description: Str,
               downloads, category: Str, publisher: Str): i64 {
    var p = alloc(48);
    store64(p,      qualified_name);
    store64(p + 8,  latest_version);
    store64(p + 16, description);
    store64(p + 24, downloads);
    store64(p + 32, category);
    store64(p + 40, publisher);
    return p;
}
fn sresult_qualified_name(p): Str { return load64(p); }
fn sresult_latest_version(p): Str { return load64(p + 8); }
fn sresult_description(p): Str    { return load64(p + 16); }
fn sresult_downloads(p): i64      { return load64(p + 24); }
fn sresult_category(p): Str       { return load64(p + 32); }
fn sresult_publisher(p): Str      { return load64(p + 40); }

fn _sresult_to_jv(p): i64 {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("qualified_name"), json_v_str_new(sresult_qualified_name(p)));
    json_v_obj_set(o, str_from("latest_version"), json_v_str_new(sresult_latest_version(p)));
    json_v_obj_set(o, str_from("description"),    json_v_str_new(sresult_description(p)));
    json_v_obj_set(o, str_from("downloads"),      json_v_int_new(sresult_downloads(p)));
    json_v_obj_set(o, str_from("category"),       json_v_str_new(sresult_category(p)));
    json_v_obj_set(o, str_from("publisher"),      json_v_str_new(sresult_publisher(p)));
    return o;
}
fn _sresult_from_jv(o): i64 {
    return sresult_new(_rc_jstr(o, "qualified_name"), _rc_jstr(o, "latest_version"),
                       _rc_jstr(o, "description"), _rc_jint(o, "downloads"),
                       _rc_jstr(o, "category"), _rc_jstr(o, "publisher"));
}

# --- SearchResults { packages: [SearchResult], total, page, per_page }
fn sresults_new(packages, total, page, per_page): i64 {
    var p = alloc(32);
    store64(p,      packages);
    store64(p + 8,  total);
    store64(p + 16, page);
    store64(p + 24, per_page);
    return p;
}
fn sresults_packages(p)      { return load64(p); }
fn sresults_total(p): i64    { return load64(p + 8); }
fn sresults_page(p): i64     { return load64(p + 16); }
fn sresults_per_page(p): i64 { return load64(p + 24); }

fn sresults_to_json(p): Str {
    var o = json_v_obj_new();
    var arr = json_v_arr_new();
    var pkgs = sresults_packages(p);
    var n = vec_len(pkgs);
    var i = 0;
    while (i < n) {
        json_v_arr_push(arr, _sresult_to_jv(vec_get(pkgs, i)));
        i = i + 1;
    }
    json_v_obj_set(o, str_from("packages"), arr);
    json_v_obj_set(o, str_from("total"),    json_v_int_new(sresults_total(p)));
    json_v_obj_set(o, str_from("page"),     json_v_int_new(sresults_page(p)));
    json_v_obj_set(o, str_from("per_page"), json_v_int_new(sresults_per_page(p)));
    return json_v_build(o);
}

# Parse a SearchResults JSON document, or 0 on a parse error / non-object root.
fn sresults_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));   # explicit buf+len (see trust.cyr)
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    var pkgs = vec_new();
    var arr = json_v_obj_get(root, "packages");
    if (json_v_is_arr(arr) == 1) {
        var n = json_v_arr_len(arr);
        var i = 0;
        while (i < n) {
            var el = json_v_arr_get(arr, i);
            if (json_v_is_obj(el) == 1) { vec_push(pkgs, _sresult_from_jv(el)); }
            i = i + 1;
        }
    }
    return sresults_new(pkgs, _rc_jint(root, "total"), _rc_jint(root, "page"),
                        _rc_jint(root, "per_page"));
}

# --- PublishResponse { name, version, download_url, replaced }
fn presp_new(name: Str, version: Str, download_url: Str, replaced): i64 {
    var p = alloc(32);
    store64(p,      name);
    store64(p + 8,  version);
    store64(p + 16, download_url);
    store64(p + 24, replaced);
    return p;
}
fn presp_name(p): Str         { return load64(p); }
fn presp_version(p): Str      { return load64(p + 8); }
fn presp_download_url(p): Str { return load64(p + 16); }
fn presp_replaced(p): i64     { return load64(p + 24); }

fn presp_to_json(p): Str {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("name"),         json_v_str_new(presp_name(p)));
    json_v_obj_set(o, str_from("version"),      json_v_str_new(presp_version(p)));
    json_v_obj_set(o, str_from("download_url"), json_v_str_new(presp_download_url(p)));
    json_v_obj_set(o, str_from("replaced"),     json_v_bool_new(presp_replaced(p)));
    return json_v_build(o);
}
fn presp_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    return presp_new(_rc_jstr(root, "name"), _rc_jstr(root, "version"),
                     _rc_jstr(root, "download_url"), _rc_jbool(root, "replaced"));
}

# --- UpdateAvailable { name, installed_version, available_version, changelog }
fn update_new(name: Str, installed_version: Str, available_version: Str, changelog: Str): i64 {
    var p = alloc(32);
    store64(p,      name);
    store64(p + 8,  installed_version);
    store64(p + 16, available_version);
    store64(p + 24, changelog);
    return p;
}
fn update_name(p): Str              { return load64(p); }
fn update_installed_version(p): Str { return load64(p + 8); }
fn update_available_version(p): Str { return load64(p + 16); }
fn update_changelog(p): Str         { return load64(p + 24); }

fn mela_update_to_json(p): Str {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("name"),              json_v_str_new(update_name(p)));
    json_v_obj_set(o, str_from("installed_version"), json_v_str_new(update_installed_version(p)));
    json_v_obj_set(o, str_from("available_version"), json_v_str_new(update_available_version(p)));
    json_v_obj_set(o, str_from("changelog"),         json_v_str_new(update_changelog(p)));
    return json_v_build(o);
}
fn update_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    return update_new(_rc_jstr(root, "name"), _rc_jstr(root, "installed_version"),
                      _rc_jstr(root, "available_version"), _rc_jstr(root, "changelog"));
}

# ---------------------------------------------------------------------------
# RegistryClient
# ---------------------------------------------------------------------------
#
# Layout (8-byte fields):
#   0  base_url   (Str; trailing slashes trimmed)
#   8  cache_dir  (Str)
#   16 offline    (i64; 0/1)

var RC_BUF_MAXLEN = 1048576;     # 1 MiB read buffer for cached responses
var RC_DIR_MODE   = 0x1FF;       # 0o777

# Trim all trailing '/' from a Str (Rust `trim_end_matches('/')`).
fn _rc_trim_trailing_slash(s: Str): Str {
    var n = str_len(s);
    var d = str_data(s);
    var go = 1;
    while (go == 1) {
        if (n == 0) { go = 0; }
        else {
            if (load8(d + n - 1) == 47) { n = n - 1; }
            else { go = 0; }
        }
    }
    return str_sub(s, 0, n);
}

fn registry_client_new(base_url: Str, cache_dir: Str): i64 {
    var c = alloc(24);
    store64(c,      _rc_trim_trailing_slash(base_url));
    store64(c + 8,  cache_dir);
    store64(c + 16, 0);
    return c;
}

fn client_base_url(c): Str  { return load64(c); }
fn client_cache_dir(c): Str { return load64(c + 8); }
fn client_is_offline(c): i64 { return load64(c + 16); }
fn client_set_offline(c, v) { store64(c + 16, v); return 0; }

# create_dir_all: mkdir every ancestor of `path` (EEXIST is harmless).
fn _rc_mkdir_p(path: Str): i64 {
    var n = str_len(path);
    var d = str_data(path);
    var i = 1;                       # skip a leading '/'
    while (i <= n) {
        var atsep = 0;
        if (i == n) { atsep = 1; }
        else { if (load8(d + i) == 47) { atsep = 1; } }
        if (atsep == 1) {
            var pre = str_clone(str_sub(path, 0, i));   # NUL-terminated prefix
            sys_mkdir(str_data(pre), RC_DIR_MODE);
        }
        i = i + 1;
    }
    return 0;
}

# ---------------------------------------------------------------------------
# Response cache (fs)
# ---------------------------------------------------------------------------

fn _rc_search_cache_path(c, query: Str): Str {
    var dir = path_join(client_cache_dir(c), str_from("search"));
    return path_join(dir, str_cat(sanitize_filename(query), str_from(".json")));
}

# cache_search_results — persist SearchResults JSON under the query key. Mirrors Rust.
fn registry_cache_search(c, query: Str, results): i64 {
    _rc_mkdir_p(path_join(client_cache_dir(c), str_from("search")));
    var path = _rc_search_cache_path(c, query);
    var js = sresults_to_json(results);
    return file_write_all(str_data(path), str_data(js), str_len(js));
}

# cached_search — load cached SearchResults, or 0 if none. Mirrors Rust.
fn registry_cached_search(c, query: Str): i64 {
    var path = _rc_search_cache_path(c, query);
    if (file_exists(str_data(path)) == 0) { return 0; }
    var buf = alloc(RC_BUF_MAXLEN);
    var n = file_read_all(str_data(path), buf, RC_BUF_MAXLEN);
    if (n <= 0) { return 0; }
    return sresults_from_json(str_new(buf, n));
}

fn _rc_manifest_cache_path(c, name: Str, version: Str): Str {
    var dir = path_join(path_join(client_cache_dir(c), str_from("manifests")), name);
    return path_join(dir, str_cat(version, str_from(".json")));
}

# cache_manifest — persist a manifest under manifests/<name>/<version>.json. Mirrors Rust.
fn registry_cache_manifest(c, name: Str, version: Str, manifest): i64 {
    _rc_mkdir_p(path_join(path_join(client_cache_dir(c), str_from("manifests")), name));
    var path = _rc_manifest_cache_path(c, name, version);
    var js = mela_manifest_to_json(manifest);
    return file_write_all(str_data(path), str_data(js), str_len(js));
}

# cached_manifest — load a cached manifest, or 0 if none. Mirrors Rust.
fn registry_cached_manifest(c, name: Str, version: Str): i64 {
    var path = _rc_manifest_cache_path(c, name, version);
    if (file_exists(str_data(path)) == 0) { return 0; }
    var buf = alloc(RC_BUF_MAXLEN);
    var n = file_read_all(str_data(path), buf, RC_BUF_MAXLEN);
    if (n <= 0) { return 0; }
    return manifest_from_json(str_new(buf, n));
}

# ---------------------------------------------------------------------------
# Real HTTP(S) transport via sandhi — v0.9.2.
# ---------------------------------------------------------------------------
#
# The transport is sandhi's full HTTP client: URL parse + DNS resolution + TLS
# (https) + HTTP/1.1-or-H2 + response framing, over real sockets. No hand-rolled
# socket loop, no IPv4-only / no-HTTPS caveats — sandhi handles all of it.

# _rc_http_get — a real GET via sandhi's HTTP client: URL parse + DNS resolve +
# TLS (for https) + HTTP/1.1-or-H2 + response framing, over real sockets. Returns
# the 2xx response body as a Str, or 0 (non-2xx, transport error, or empty URL).
# Both http:// and https:// work, and hosts are resolved by name (no IPv4-only
# limitation). `url` is passed as a NUL-terminated cstring (str_clone ensures it).
fn _rc_http_get(url: Str): i64 {
    if (str_len(url) == 0) { return 0; }
    var curl = str_clone(url);                       # NUL-terminated for sandhi
    var opts = sandhi_http_options_new();
    var r = sandhi_http_get_auto(str_data(curl), 0, opts);   # no extra headers
    if (r == 0) { return 0; }
    var status = sandhi_http_status(r);
    if (status < 200) { return 0; }
    if (status >= 300) { return 0; }                 # only 2xx bodies
    var blen = sandhi_http_body_len(r);
    if (blen <= 0) { return str_from(""); }
    return str_new(sandhi_http_body(r), blen);
}

# search — offline: cached results (0 if none). online: real GET + parse, and
# cache the result. Mirrors Rust `search`.
fn rc_search(c, query: Str, category: Str, has_category, page): i64 {
    if (client_is_offline(c) == 1) { return registry_cached_search(c, query); }
    var url = build_search_url(client_base_url(c), query, category, has_category, page);
    var resp = _rc_http_get(url);                 # Str body, or 0
    if (resp == 0) { return 0; }
    var results = sresults_from_json(resp);
    if (results != 0) { registry_cache_search(c, query, results); }
    return results;
}

# fetch_manifest — validate segments, then offline: cached (0 if none); online:
# real GET + parse + cache. Returns 0 on an invalid name/version. Mirrors Rust.
fn rc_fetch_manifest(c, name: Str, version: Str): i64 {
    if (validate_path_segment(name) == 0) { return 0; }
    if (validate_path_segment(version) == 0) { return 0; }
    if (client_is_offline(c) == 1) { return registry_cached_manifest(c, name, version); }
    var resp = _rc_http_get(build_manifest_url(client_base_url(c), name, version));
    if (resp == 0) { return 0; }
    var manifest = manifest_from_json(resp);
    if (manifest != 0) { registry_cache_manifest(c, name, version, manifest); }
    return manifest;
}

# download guard — 1 if a download would proceed (online + valid segments), 0 if
# blocked (offline) or the name/version is invalid. The guard half of `download_package`.
fn rc_download_allowed(c, name: Str, version: Str): i64 {
    if (validate_path_segment(name) == 0) { return 0; }
    if (validate_path_segment(version) == 0) { return 0; }
    if (client_is_offline(c) == 1) { return 0; }    # "Cannot download in offline mode"
    return 1;
}

# download — actually FETCH the package and WRITE it to the cache, returning the
# saved path (or 0 on a blocked/invalid/transport/write failure). Mirrors Rust
# `download_package`: GET {base}/v1/packages/{name}/{version}/download over the
# real sandhi transport, then write the body to
# <cache_dir>/downloads/<name>-<version>.agnos-agent. No longer a guard-only stub.
fn rc_download(c, name: Str, version: Str): i64 {
    if (rc_download_allowed(c, name, version) == 0) { return 0; }
    var bytes = _rc_http_get(build_download_url(client_base_url(c), name, version));
    if (bytes == 0) { return 0; }                    # transport / non-2xx failure
    var dl_dir = path_join(client_cache_dir(c), str_from("downloads"));
    _rc_mkdir_p(dl_dir);
    var fname = str_cat(str_cat(str_cat(name, str_from("-")), version), str_from(".agnos-agent"));
    var dest = path_join(dl_dir, fname);
    if (file_write_all(str_data(dest), str_data(bytes), str_len(bytes)) < 0) { return 0; }
    return dest;
}

# publish guard — 1 if a publish would proceed (online), 0 if blocked (offline).
fn rc_publish_allowed(c): i64 {
    if (client_is_offline(c) == 1) { return 0; }    # "Cannot publish in offline mode"
    return 1;
}

# publish — actually UPLOAD the bundle: POST it to {base}/v1/packages/publish over
# the real sandhi transport with a Bearer token + SHA-256 / name headers, then
# parse the registry's PublishResponse. Returns the PublishResponse, or 0 (offline,
# transport/non-2xx, or unparseable body). Mirrors Rust `publish`.
fn rc_publish(c, bundle: Str, bundle_name: Str, api_token: Str): i64 {
    if (client_is_offline(c) == 1) { return 0; }
    var sha = trust_hash_data(str_data(bundle), str_len(bundle));
    var h = sandhi_headers_new();
    sandhi_headers_add(h, "Authorization", str_data(str_clone(str_cat(str_from("Bearer "), api_token))));
    sandhi_headers_add(h, "Content-Type", "application/octet-stream");
    sandhi_headers_add(h, "X-Package-SHA256", str_data(str_clone(sha)));
    sandhi_headers_add(h, "X-Package-Name", str_data(str_clone(bundle_name)));
    var url = str_clone(build_publish_url(client_base_url(c)));
    var r = sandhi_http_post_auto(str_data(url), h, str_data(bundle), str_len(bundle), sandhi_http_options_new());
    if (r == 0) { return 0; }
    var status = sandhi_http_status(r);
    if (status < 200) { return 0; }
    if (status >= 300) { return 0; }
    var blen = sandhi_http_body_len(r);
    if (blen <= 0) { return 0; }
    return presp_from_json(str_new(sandhi_http_body(r), blen));
}

# check_updates — offline returns an empty Vec (Rust `check_updates` early-return).
# Online: for each installed package, fetch its latest manifest and diff the
# version; collect UpdateAvailable for any that differ.
fn rc_check_updates(c, installed): i64 {
    var out = vec_new();
    if (client_is_offline(c) == 1) { return out; }
    var n = vec_len(installed);
    var i = 0;
    while (i < n) {
        var pkg = vec_get(installed, i);                 # InstalledMarketplacePackage
        var name = imp_name(pkg);
        var resp = _rc_http_get(build_latest_url(client_base_url(c), name));
        if (resp != 0) {
            var latest = manifest_from_json(resp);
            if (latest != 0) {
                if (str_eq(man_version(latest), imp_version(pkg)) == 0) {
                    vec_push(out, update_new(name, imp_version(pkg), man_version(latest),
                                             man_changelog(latest)));
                }
            }
        }
        i = i + 1;
    }
    return out;
}

# --- sandbox_profiles.cyr ---

# sandbox_profiles.cyr — curated sandbox profiles for known app types.
#
# Ports rust-old/src/sandbox_profiles.rs: predefined Landlock/seccomp/network
# profiles per app category, the Photis Nadi / Aequi specific profiles, the
# generic preset builder, and profile validation.
#
# LandlockRule / NetworkRule are defined here as plain structs. In the Rust
# oracle they live in flutter_agpkg (the v0.8.0 packaging module); when that
# ports, it shares these shapes. Pure data + validation — no new deps.

# ---------------------------------------------------------------------------
# SandboxPreset
# ---------------------------------------------------------------------------

var SP_PHOTO_EDITOR    = 0;
var SP_PRODUCTIVITY    = 1;
var SP_BROWSER         = 2;
var SP_GAME            = 3;
var SP_CLI_TOOL        = 4;
var SP_GPU_COMPUTE     = 5;
var SP_CUSTOM          = 6;

# Display name (Rust `impl Display`).
fn sandbox_preset_name(p): Str {
    if (p == SP_PHOTO_EDITOR) { return str_from("photo-editor"); }
    if (p == SP_PRODUCTIVITY) { return str_from("productivity-app"); }
    if (p == SP_BROWSER)      { return str_from("browser"); }
    if (p == SP_GAME)         { return str_from("game-app"); }
    if (p == SP_CLI_TOOL)     { return str_from("cli-tool"); }
    if (p == SP_GPU_COMPUTE)  { return str_from("gpu-compute"); }
    if (p == SP_CUSTOM)       { return str_from("custom"); }
    return str_from("");
}

# ---------------------------------------------------------------------------
# LandlockRule { path, access } / NetworkRule { enabled, allowed_hosts }
# ---------------------------------------------------------------------------

fn ll_new(path: Str, access: Str): i64 {
    var r = alloc(16);
    store64(r,     path);
    store64(r + 8, access);
    return r;
}
fn ll_path(r): Str   { return load64(r); }
fn ll_access(r): Str { return load64(r + 8); }

fn nr_new(enabled, allowed_hosts): i64 {
    var n = alloc(16);
    store64(n,     enabled);
    store64(n + 8, allowed_hosts);
    return n;
}
fn nr_enabled(n): i64 { return load64(n); }
fn nr_hosts(n)        { return load64(n + 8); }

# Vec<Str> builders for landlock-rule / host lists.
fn _rules(): i64 { return vec_new(); }
fn _rule(rules, path, access): i64 { vec_push(rules, ll_new(str_from(path), str_from(access))); return rules; }
fn _hosts0(): i64 { return vec_new(); }
fn _host(hosts, h): i64 { vec_push(hosts, str_from(h)); return hosts; }

# ---------------------------------------------------------------------------
# PredefinedProfile
# ---------------------------------------------------------------------------
#
#   0  preset (i64)           8  landlock_rules (Vec<LandlockRule>)
#   16 seccomp_mode (Str)     24 network (NetworkRule*)
#   32 max_memory_mb (i64)    40 allow_process_spawn (i64)

fn profile_new(preset, landlock_rules, seccomp_mode: Str, network, max_memory_mb, allow_process_spawn): i64 {
    var p = alloc(48);
    store64(p,      preset);
    store64(p + 8,  landlock_rules);
    store64(p + 16, seccomp_mode);
    store64(p + 24, network);
    store64(p + 32, max_memory_mb);
    store64(p + 40, allow_process_spawn);
    return p;
}
fn profile_preset(p): i64          { return load64(p); }
fn profile_landlock_rules(p)       { return load64(p + 8); }
fn profile_seccomp_mode(p): Str    { return load64(p + 16); }
fn profile_network(p)              { return load64(p + 24); }
fn profile_max_memory_mb(p): i64   { return load64(p + 32); }
fn profile_allow_process_spawn(p): i64 { return load64(p + 40); }

# ---------------------------------------------------------------------------
# Specific profiles
# ---------------------------------------------------------------------------

# Photis Nadi (Flutter photo editor; Supabase backend + local Hive DB).
fn build_photis_nadi_profile(): i64 {
    var rules = _rules();
    _rule(rules, "~/.local/share/photisnadi/", "rw");
    _rule(rules, "/tmp", "rw");
    _rule(rules, "/usr/share/fonts", "ro");
    var net = nr_new(1, _host(_host(_hosts0(), "*.supabase.co"), "*.supabase.in"));
    return profile_new(SP_PHOTO_EDITOR, rules, str_from("desktop"), net, 512, 0);
}

# Aequi (Tauri accounting; local SQLite + optional Tesseract OCR).
fn build_aequi_profile(): i64 {
    var rules = _rules();
    _rule(rules, "~/.local/share/aequi/", "rw");
    _rule(rules, "/tmp", "rw");
    _rule(rules, "/usr/share/fonts", "ro");
    _rule(rules, "/usr/share/tesseract-ocr", "ro");
    _rule(rules, "/usr/share/aequi/rules", "ro");
    var net = nr_new(0, _hosts0());
    return profile_new(SP_PRODUCTIVITY, rules, str_from("desktop"), net, 512, 0);
}

# ---------------------------------------------------------------------------
# Generic preset builder
# ---------------------------------------------------------------------------

fn _build_photo_editor(data_dir): i64 {
    var rules = _rules();
    _rule(rules, data_dir, "rw");
    _rule(rules, "/tmp", "rw");
    _rule(rules, "/usr/share/fonts", "ro");
    return profile_new(SP_PHOTO_EDITOR, rules, str_from("desktop"), nr_new(0, _hosts0()), 512, 0);
}

fn _build_productivity(data_dir): i64 {
    var rules = _rules();
    _rule(rules, data_dir, "rw");
    _rule(rules, "/tmp", "rw");
    _rule(rules, "/usr/share/fonts", "ro");
    _rule(rules, "~/Documents", "rw");
    return profile_new(SP_PRODUCTIVITY, rules, str_from("desktop"), nr_new(1, _hosts0()), 1024, 0);
}

fn _build_browser(data_dir): i64 {
    var rules = _rules();
    _rule(rules, data_dir, "rw");
    _rule(rules, "/tmp", "rw");
    _rule(rules, "/usr/share/fonts", "ro");
    _rule(rules, "~/Downloads", "rw");
    return profile_new(SP_BROWSER, rules, str_from("desktop"), nr_new(1, _host(_hosts0(), "*")), 2048, 1);
}

fn _build_game(data_dir): i64 {
    var rules = _rules();
    _rule(rules, data_dir, "rw");
    _rule(rules, "/tmp", "rw");
    _rule(rules, "/usr/share/fonts", "ro");
    return profile_new(SP_GAME, rules, str_from("desktop"), nr_new(1, _hosts0()), 4096, 0);
}

fn _build_cli_tool(data_dir): i64 {
    var rules = _rules();
    _rule(rules, data_dir, "rw");
    _rule(rules, "/tmp", "rw");
    return profile_new(SP_CLI_TOOL, rules, str_from("basic"), nr_new(0, _hosts0()), 256, 1);
}

fn _build_gpu_compute(data_dir): i64 {
    var rules = _rules();
    _rule(rules, data_dir, "rw");
    _rule(rules, "/tmp", "rw");
    _rule(rules, "/dev/dri", "rw");
    _rule(rules, "/dev/nvidia0", "rw");
    _rule(rules, "/dev/nvidia1", "rw");
    _rule(rules, "/dev/nvidiactl", "rw");
    _rule(rules, "/dev/nvidia-uvm", "rw");
    _rule(rules, "/dev/nvidia-uvm-tools", "rw");
    _rule(rules, "/dev/kfd", "rw");
    _rule(rules, "/usr/lib/cuda", "ro");
    _rule(rules, "/usr/local/cuda", "ro");
    _rule(rules, "/opt/rocm", "ro");
    _rule(rules, "/usr/lib/x86_64-linux-gnu", "ro");
    var hosts = _hosts0();
    _host(hosts, "localhost");
    _host(hosts, "127.0.0.1");
    _host(hosts, "huggingface.co");
    _host(hosts, "*.huggingface.co");
    _host(hosts, "hf.co");
    _host(hosts, "*.hf.co");
    return profile_new(SP_GPU_COMPUTE, rules, str_from("desktop"), nr_new(1, hosts), 4096, 1);
}

# build_profile_for_preset(preset, app_name, data_dir). app_name is unused by
# the presets (Rust ignores it too), kept for signature parity.
fn build_profile_for_preset(preset, app_name: Str, data_dir: Str): i64 {
    if (preset == SP_PHOTO_EDITOR) { return _build_photo_editor(data_dir); }
    if (preset == SP_PRODUCTIVITY) { return _build_productivity(data_dir); }
    if (preset == SP_BROWSER)      { return _build_browser(data_dir); }
    if (preset == SP_GAME)         { return _build_game(data_dir); }
    if (preset == SP_CLI_TOOL)     { return _build_cli_tool(data_dir); }
    if (preset == SP_GPU_COMPUTE)  { return _build_gpu_compute(data_dir); }
    # Custom: single rw rule on data_dir, basic seccomp, no network.
    var rules = _rules();
    vec_push(rules, ll_new(data_dir, str_from("rw")));
    return profile_new(SP_CUSTOM, rules, str_from("basic"), nr_new(0, _hosts0()), 256, 0);
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

# Returns "" if the profile is valid, else the first problem (Rust `bail!`
# messages). Mirrors Rust `validate_profile`.
fn validate_profile(profile): Str {
    var rules = profile_landlock_rules(profile);
    var n = vec_len(rules);
    if (n == 0) { return str_from("profile must have at least one Landlock rule"); }

    # access modes
    var i = 0;
    var bad_access = 0;
    while (i < n) {
        if (bad_access == 0) {
            var acc = ll_access(vec_get(rules, i));
            var ok = 0;
            if (str_eq_cstr(acc, "ro") == 1) { ok = 1; }
            if (str_eq_cstr(acc, "rw") == 1) { ok = 1; }
            if (ok == 0) { bad_access = 1; }
        }
        i = i + 1;
    }
    if (bad_access == 1) { return str_from("invalid Landlock access mode (expected 'ro' or 'rw')"); }

    # non-empty paths
    var j = 0;
    var empty_path = 0;
    while (j < n) {
        if (str_len(ll_path(vec_get(rules, j))) == 0) { empty_path = 1; }
        j = j + 1;
    }
    if (empty_path == 1) { return str_from("Landlock rule has an empty path"); }

    # seccomp mode
    var sm = profile_seccomp_mode(profile);
    var sm_ok = 0;
    if (str_eq_cstr(sm, "basic") == 1)   { sm_ok = 1; }
    if (str_eq_cstr(sm, "desktop") == 1) { sm_ok = 1; }
    if (str_eq_cstr(sm, "strict") == 1)  { sm_ok = 1; }
    if (sm_ok == 0) { return str_from("unknown seccomp mode (expected basic, desktop, or strict)"); }

    # memory
    if (profile_max_memory_mb(profile) == 0) { return str_from("max_memory_mb must be greater than zero"); }

    # network disabled but hosts present
    var net = profile_network(profile);
    if (nr_enabled(net) == 0) {
        if (vec_len(nr_hosts(net)) != 0) { return str_from("network is disabled but allowed_hosts is non-empty"); }
    }
    return str_from("");
}

# Convenience: does the profile contain a landlock rule whose path contains
# `needle` (for tests that assert device/host presence).
fn profile_has_rule_containing(profile, needle: Str): i64 {
    var rules = profile_landlock_rules(profile);
    var n = vec_len(rules);
    var i = 0;
    var hit = 0;
    while (i < n) {
        if (hit == 0) {
            if (str_contains(ll_path(vec_get(rules, i)), needle) == 1) { hit = 1; }
        }
        i = i + 1;
    }
    return hit;
}

# Convenience: does a landlock rule (path, access) pair exist exactly.
fn profile_has_rule(profile, path: Str, access: Str): i64 {
    var rules = profile_landlock_rules(profile);
    var n = vec_len(rules);
    var i = 0;
    var hit = 0;
    while (i < n) {
        if (hit == 0) {
            var r = vec_get(rules, i);
            if (str_eq(ll_path(r), path) == 1) {
                if (str_eq(ll_access(r), access) == 1) { hit = 1; }
            }
        }
        i = i + 1;
    }
    return hit;
}

# Convenience: does the network rule allow `host` exactly.
fn profile_allows_host(profile, host: Str): i64 {
    var hosts = nr_hosts(profile_network(profile));
    var n = vec_len(hosts);
    var i = 0;
    var hit = 0;
    while (i < n) {
        if (str_eq(vec_get(hosts, i), host) == 1) { hit = 1; }
        i = i + 1;
    }
    return hit;
}

# ---------------------------------------------------------------------------
# JSON codec (preset as serde PascalCase variant name; ADR-0001 wire style)
# ---------------------------------------------------------------------------

fn sandbox_preset_json_name(p): Str {
    if (p == SP_PHOTO_EDITOR) { return str_from("PhotoEditor"); }
    if (p == SP_PRODUCTIVITY) { return str_from("ProductivityApp"); }
    if (p == SP_BROWSER)      { return str_from("Browser"); }
    if (p == SP_GAME)         { return str_from("GameApp"); }
    if (p == SP_CLI_TOOL)     { return str_from("CliTool"); }
    if (p == SP_GPU_COMPUTE)  { return str_from("GpuCompute"); }
    return str_from("Custom");
}
fn sandbox_preset_json_parse(s: Str): i64 {
    if (str_eq_cstr(s, "PhotoEditor") == 1)     { return SP_PHOTO_EDITOR; }
    if (str_eq_cstr(s, "ProductivityApp") == 1) { return SP_PRODUCTIVITY; }
    if (str_eq_cstr(s, "Browser") == 1)         { return SP_BROWSER; }
    if (str_eq_cstr(s, "GameApp") == 1)         { return SP_GAME; }
    if (str_eq_cstr(s, "CliTool") == 1)         { return SP_CLI_TOOL; }
    if (str_eq_cstr(s, "GpuCompute") == 1)      { return SP_GPU_COMPUTE; }
    return SP_CUSTOM;
}

fn _sp_jstr(o, key): Str {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}
fn _sp_jint(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_int(v) == 0) { return 0; }
    return json_v_int(v);
}
fn _sp_jbool(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_bool(v) == 0) { return 0; }
    return json_v_bool(v);
}

fn profile_to_json(p): Str {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("preset"), json_v_str_new(sandbox_preset_json_name(profile_preset(p))));
    var arr = json_v_arr_new();
    var rules = profile_landlock_rules(p);
    var n = vec_len(rules);
    var i = 0;
    while (i < n) {
        var r = vec_get(rules, i);
        var ro = json_v_obj_new();
        json_v_obj_set(ro, str_from("path"),   json_v_str_new(ll_path(r)));
        json_v_obj_set(ro, str_from("access"), json_v_str_new(ll_access(r)));
        json_v_arr_push(arr, ro);
        i = i + 1;
    }
    json_v_obj_set(o, str_from("landlock_rules"), arr);
    json_v_obj_set(o, str_from("seccomp_mode"), json_v_str_new(profile_seccomp_mode(p)));
    var net = profile_network(p);
    var no = json_v_obj_new();
    json_v_obj_set(no, str_from("enabled"), json_v_bool_new(nr_enabled(net)));
    var ha = json_v_arr_new();
    var hosts = nr_hosts(net);
    var hn = vec_len(hosts);
    var hi = 0;
    while (hi < hn) { json_v_arr_push(ha, json_v_str_new(vec_get(hosts, hi))); hi = hi + 1; }
    json_v_obj_set(no, str_from("allowed_hosts"), ha);
    json_v_obj_set(o, str_from("network"), no);
    json_v_obj_set(o, str_from("max_memory_mb"),        json_v_int_new(profile_max_memory_mb(p)));
    json_v_obj_set(o, str_from("allow_process_spawn"),  json_v_bool_new(profile_allow_process_spawn(p)));
    return json_v_build(o);
}

fn profile_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }

    var preset = SP_CUSTOM;
    var pv = json_v_obj_get(root, "preset");
    if (json_v_is_str(pv) == 1) { preset = sandbox_preset_json_parse(json_v_str(pv)); }

    var rules = vec_new();
    var arr = json_v_obj_get(root, "landlock_rules");
    if (json_v_is_arr(arr) == 1) {
        var n = json_v_arr_len(arr);
        var i = 0;
        while (i < n) {
            var ro = json_v_arr_get(arr, i);
            vec_push(rules, ll_new(_sp_jstr(ro, "path"), _sp_jstr(ro, "access")));
            i = i + 1;
        }
    }

    var hosts = vec_new();
    var enabled = 0;
    var net_in = json_v_obj_get(root, "network");
    if (json_v_is_obj(net_in) == 1) {
        enabled = _sp_jbool(net_in, "enabled");
        var ha = json_v_obj_get(net_in, "allowed_hosts");
        if (json_v_is_arr(ha) == 1) {
            var hn = json_v_arr_len(ha);
            var hi = 0;
            while (hi < hn) {
                var el = json_v_arr_get(ha, hi);
                if (json_v_is_str(el) == 1) { vec_push(hosts, json_v_str(el)); }
                hi = hi + 1;
            }
        }
    }
    return profile_new(preset, rules, _sp_jstr(root, "seccomp_mode"), nr_new(enabled, hosts),
                       _sp_jint(root, "max_memory_mb"), _sp_jbool(root, "allow_process_spawn"));
}

# --- ratings.cyr ---

# ratings.cyr — agent/user ratings & reviews for marketplace packages.
#
# Ports rust-old/src/ratings.rs: a deduplicating rating store (one rating per
# agent per package, latest wins), aggregate stats, filtered queries, top-rated
# ranking, and JSON persistence.
#
# average_score is a real f64 (Cyrius f64 builtins: f64_from/to/div/gt/lt) — the
# store persists integer scores and recomputes stats on read, so no float ever
# round-trips through disk (ADR-0007). created_at is an i64 epoch supplied
# explicitly (ADR-0003/0004 precedent), not chrono.

var MAX_REVIEW_LENGTH = 2000;
var MIN_SCORE = 1;
var MAX_SCORE = 5;

# ---------------------------------------------------------------------------
# Rating
# ---------------------------------------------------------------------------
#
#   0 agent_id (Str)  8 package_name (Str)  16 score (i64)
#   24 has_review (i64)  32 review (Str)  40 created_at (i64)  48 version_reviewed (Str)

fn rating_new(agent_id: Str, package_name: Str, score, has_review, review: Str,
              created_at, version_reviewed: Str): i64 {
    var r = alloc(56);
    store64(r,      agent_id);
    store64(r + 8,  package_name);
    store64(r + 16, score);
    store64(r + 24, has_review);
    store64(r + 32, review);
    store64(r + 40, created_at);
    store64(r + 48, version_reviewed);
    return r;
}
fn rating_agent_id(r): Str     { return load64(r); }
fn rating_package_name(r): Str { return load64(r + 8); }
fn rating_score(r): i64        { return load64(r + 16); }
fn rating_has_review(r): i64   { return load64(r + 24); }
fn rating_review(r): Str       { return load64(r + 32); }
fn rating_created_at(r): i64   { return load64(r + 40); }
fn rating_version(r): Str      { return load64(r + 48); }

# ---------------------------------------------------------------------------
# RatingStats
# ---------------------------------------------------------------------------
#
#   0 package_name (Str)  8 average_score (f64 bits)  16 total_ratings (i64)
#   24 distribution (ptr to 6 i64, indexed by score)  32 has_latest (i64)  40 latest_review (i64)

fn _dist_new(): i64 {
    var d = alloc(48);
    var i = 0;
    while (i < 6) { store64(d + i * 8, 0); i = i + 1; }
    return d;
}

fn stats_package_name(s): Str  { return load64(s); }
fn stats_average_score(s): i64 { return load64(s + 8); }   # f64 bits
fn stats_total_ratings(s): i64 { return load64(s + 16); }
fn stats_distribution(s)       { return load64(s + 24); }
fn stats_has_latest(s): i64    { return load64(s + 32); }
fn stats_latest_review(s): i64 { return load64(s + 40); }
fn stats_dist(s, score): i64   { return load64(load64(s + 24) + score * 8); }

# ---------------------------------------------------------------------------
# RatingFilter
# ---------------------------------------------------------------------------
#
#   0  has_min_score  8  min_score
#   16 has_package    24 package_name (Str)
#   32 has_agent      40 agent_id (Str)
#   48 has_from       56 from (i64)
#   64 has_until      72 until (i64)

fn filter_new(): i64 {
    var f = alloc(80);
    var i = 0;
    while (i < 10) { store64(f + i * 8, 0); i = i + 1; }
    return f;
}
fn filter_set_min_score(f, v) { store64(f, 1); store64(f + 8, v); return 0; }
fn filter_set_package(f, v: Str) { store64(f + 16, 1); store64(f + 24, v); return 0; }
fn filter_set_agent(f, v: Str) { store64(f + 32, 1); store64(f + 40, v); return 0; }
fn filter_set_from(f, v) { store64(f + 48, 1); store64(f + 56, v); return 0; }
fn filter_set_until(f, v) { store64(f + 64, 1); store64(f + 72, v); return 0; }

# matches(rating) — true if the rating satisfies every set criterion. Mirrors
# Rust `RatingFilter::matches`.
fn filter_matches(f, rating): i64 {
    if (load64(f) == 1) {                       # min_score
        if (rating_score(rating) < load64(f + 8)) { return 0; }
    }
    if (load64(f + 16) == 1) {                  # package_name
        if (str_eq(rating_package_name(rating), load64(f + 24)) == 0) { return 0; }
    }
    if (load64(f + 32) == 1) {                  # agent_id
        if (str_eq(rating_agent_id(rating), load64(f + 40)) == 0) { return 0; }
    }
    if (load64(f + 48) == 1) {                  # from
        if (rating_created_at(rating) < load64(f + 56)) { return 0; }
    }
    if (load64(f + 64) == 1) {                  # until
        if (rating_created_at(rating) > load64(f + 72)) { return 0; }
    }
    return 1;
}

# ---------------------------------------------------------------------------
# RatingStore — package_name -> (agent_id -> Rating)
# ---------------------------------------------------------------------------

fn rstore_new(): i64 { return map_new_str(); }

# add_rating — validate + dedup-insert (latest wins). Returns the Rating, or 0 on
# a validation failure (empty agent/package, score out of 1..5, review too long).
# Takes an explicit created_at (Rust used Utc::now()). Mirrors Rust `add_rating`.
fn rstore_add_rating(store, agent_id: Str, package_name: Str, score, has_review,
                     review: Str, version_reviewed: Str, created_at): i64 {
    if (str_len(agent_id) == 0) { return 0; }
    if (str_len(package_name) == 0) { return 0; }
    if (score < MIN_SCORE) { return 0; }
    if (score > MAX_SCORE) { return 0; }
    if (has_review == 1) {
        if (str_len(review) > MAX_REVIEW_LENGTH) { return 0; }
    }
    var rating = rating_new(agent_id, package_name, score, has_review, review,
                            created_at, version_reviewed);
    var pkg_map = map_get(store, package_name);
    if (pkg_map == 0) {
        pkg_map = map_new_str();
        map_set(store, package_name, pkg_map);
    }
    map_set(pkg_map, agent_id, rating);          # dedup: same agent overwrites
    return rating;
}

fn rstore_package_count(store): i64 { return map_size(store); }

# total_count — unique ratings across all packages. Mirrors Rust `total_count`.
fn rstore_total_count(store): i64 {
    var maps = map_values(store);
    var n = vec_len(maps);
    var i = 0;
    var total = 0;
    while (i < n) {
        total = total + map_size(vec_get(maps, i));
        i = i + 1;
    }
    return total;
}

# Collect every Rating in the store into a fresh Vec.
fn _rstore_all_ratings(store): i64 {
    var out = vec_new();
    var maps = map_values(store);
    var n = vec_len(maps);
    var i = 0;
    while (i < n) {
        var ratings = map_values(vec_get(maps, i));
        var rn = vec_len(ratings);
        var j = 0;
        while (j < rn) {
            vec_push(out, vec_get(ratings, j));
            j = j + 1;
        }
        i = i + 1;
    }
    return out;
}

# Sort a Vec<Rating> by created_at descending (newest first), in place.
fn _sort_ratings_desc(v): i64 {
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        var max_idx = i;
        var j = i + 1;
        while (j < n) {
            if (rating_created_at(vec_get(v, j)) > rating_created_at(vec_get(v, max_idx))) { max_idx = j; }
            j = j + 1;
        }
        var tmp = vec_get(v, i);
        vec_set(v, i, vec_get(v, max_idx));
        vec_set(v, max_idx, tmp);
        i = i + 1;
    }
    return 0;
}

# get_ratings(filter) — all matching ratings, newest first. Mirrors Rust `get_ratings`.
fn rstore_get_ratings(store, filter): i64 {
    var all = _rstore_all_ratings(store);
    var out = vec_new();
    var n = vec_len(all);
    var i = 0;
    while (i < n) {
        var r = vec_get(all, i);
        if (filter_matches(filter, r) == 1) { vec_push(out, r); }
        i = i + 1;
    }
    _sort_ratings_desc(out);
    return out;
}

# get_stats(package_name) — aggregate stats, or 0 if the package has no ratings.
# Mirrors Rust `get_stats`.
fn rstore_get_stats(store, package_name: Str): i64 {
    var pkg_map = map_get(store, package_name);
    if (pkg_map == 0) { return 0; }
    var ratings = map_values(pkg_map);
    var count = vec_len(ratings);
    if (count == 0) { return 0; }

    var dist = _dist_new();
    var total = 0;
    var has_latest = 0;
    var latest = 0;
    var i = 0;
    while (i < count) {
        var r = vec_get(ratings, i);
        var sc = rating_score(r);
        store64(dist + sc * 8, load64(dist + sc * 8) + 1);
        total = total + sc;
        if (has_latest == 0) { has_latest = 1; latest = rating_created_at(r); }
        else { if (rating_created_at(r) > latest) { latest = rating_created_at(r); } }
        i = i + 1;
    }

    var s = alloc(48);
    store64(s,      package_name);
    store64(s + 8,  f64_div(f64_from(total), f64_from(count)));
    store64(s + 16, count);
    store64(s + 24, dist);
    store64(s + 32, has_latest);
    store64(s + 40, latest);
    return s;
}

# top_rated(has_min, min_ratings) — packages ranked by average desc, total
# desc on ties; packages below the min-ratings threshold excluded. Mirrors Rust.
fn rstore_top_rated(store, has_min, min_ratings): i64 {
    var threshold = 0;
    if (has_min == 1) { threshold = min_ratings; }
    var keys = map_keys(store);
    var n = vec_len(keys);
    var out = vec_new();
    var i = 0;
    while (i < n) {
        var st = rstore_get_stats(store, vec_get(keys, i));
        if (st != 0) {
            if (stats_total_ratings(st) >= threshold) { vec_push(out, st); }
        }
        i = i + 1;
    }
    # selection sort: average_score desc, then total_ratings desc
    var m = vec_len(out);
    var a = 0;
    while (a < m) {
        var best = a;
        var b = a + 1;
        while (b < m) {
            if (_stats_better(vec_get(out, b), vec_get(out, best)) == 1) { best = b; }
            b = b + 1;
        }
        var tmp = vec_get(out, a);
        vec_set(out, a, vec_get(out, best));
        vec_set(out, best, tmp);
        a = a + 1;
    }
    return out;
}

# True if stats `x` ranks above `y` (higher average, or equal average + higher total).
fn _stats_better(x, y): i64 {
    var ax = stats_average_score(x);
    var ay = stats_average_score(y);
    if (f64_gt(ax, ay) == 1) { return 1; }
    if (f64_lt(ax, ay) == 1) { return 0; }
    if (stats_total_ratings(x) > stats_total_ratings(y)) { return 1; }
    return 0;
}

# ---------------------------------------------------------------------------
# JSON codec + persistence (ADR-0001 wire style; ratings store on disk)
# ---------------------------------------------------------------------------

var RATINGS_MAXLEN = 1048576;    # 1 MiB read buffer

fn _r_jstr(o, key): Str {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}
fn _r_jint(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_int(v) == 0) { return 0; }
    return json_v_int(v);
}

fn _rating_to_jv(r): i64 {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("agent_id"),     json_v_str_new(rating_agent_id(r)));
    json_v_obj_set(o, str_from("package_name"), json_v_str_new(rating_package_name(r)));
    json_v_obj_set(o, str_from("score"),        json_v_int_new(rating_score(r)));
    if (rating_has_review(r) == 1) {
        json_v_obj_set(o, str_from("review"), json_v_str_new(rating_review(r)));
    } else {
        json_v_obj_set(o, str_from("review"), json_v_null());
    }
    json_v_obj_set(o, str_from("created_at"),       json_v_int_new(rating_created_at(r)));
    json_v_obj_set(o, str_from("version_reviewed"), json_v_str_new(rating_version(r)));
    return o;
}

fn _rating_from_jv(o): i64 {
    var rv = json_v_obj_get(o, "review");
    var has_review = 0;
    var review = str_from("");
    if (json_v_is_str(rv) == 1) { has_review = 1; review = json_v_str(rv); }
    return rating_new(_r_jstr(o, "agent_id"), _r_jstr(o, "package_name"), _r_jint(o, "score"),
                      has_review, review, _r_jint(o, "created_at"), _r_jstr(o, "version_reviewed"));
}

fn rating_to_json(r): Str { return json_v_build(_rating_to_jv(r)); }
fn rating_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    return _rating_from_jv(root);
}

# RatingStats <-> JSON (distribution as {score:count}; latest as int or null).
fn stats_to_json(s): Str {
    var o = json_v_obj_new();
    json_v_obj_set(o, str_from("package_name"),  json_v_str_new(stats_package_name(s)));
    json_v_obj_set(o, str_from("average_score"), json_v_float_new(stats_average_score(s)));
    json_v_obj_set(o, str_from("total_ratings"), json_v_int_new(stats_total_ratings(s)));
    var dist_o = json_v_obj_new();
    var score = 1;
    while (score <= 5) {
        var c = stats_dist(s, score);
        if (c > 0) { json_v_obj_set(dist_o, str_from_int(score), json_v_int_new(c)); }
        score = score + 1;
    }
    json_v_obj_set(o, str_from("distribution"), dist_o);
    if (stats_has_latest(s) == 1) {
        json_v_obj_set(o, str_from("latest_review"), json_v_int_new(stats_latest_review(s)));
    } else {
        json_v_obj_set(o, str_from("latest_review"), json_v_null());
    }
    return json_v_build(o);
}

fn stats_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    var dist = _dist_new();
    var dv = json_v_obj_get(root, "distribution");
    if (json_v_is_obj(dv) == 1) {
        var n = json_v_obj_len(dv);
        var i = 0;
        while (i < n) {
            var k = json_v_obj_key(dv, i);            # "1".."5"
            var v = json_v_obj_val(dv, i);
            if (str_len(k) > 0) {
                var sc = load8(str_data(k)) - 48;     # single-digit score
                if (sc >= 1) {
                    if (sc <= 5) {
                        if (json_v_is_int(v) == 1) { store64(dist + sc * 8, json_v_int(v)); }
                    }
                }
            }
            i = i + 1;
        }
    }
    var has_latest = 0;
    var latest = 0;
    var lv = json_v_obj_get(root, "latest_review");
    if (json_v_is_int(lv) == 1) { has_latest = 1; latest = json_v_int(lv); }
    var avg = f64_from(0);
    var av = json_v_obj_get(root, "average_score");
    if (json_v_is_float(av) == 1) { avg = json_v_float(av); }
    if (json_v_is_int(av) == 1)   { avg = f64_from(json_v_int(av)); }
    var s = alloc(48);
    store64(s,      _r_jstr(root, "package_name"));
    store64(s + 8,  avg);
    store64(s + 16, _r_jint(root, "total_ratings"));
    store64(s + 24, dist);
    store64(s + 32, has_latest);
    store64(s + 40, latest);
    return s;
}

# RatingStore <-> JSON: { package: { agent_id: rating } }.
fn rstore_to_json(store): Str {
    var o = json_v_obj_new();
    var pkgs = map_keys(store);
    var pn = vec_len(pkgs);
    var i = 0;
    while (i < pn) {
        var pkg = vec_get(pkgs, i);
        var pkg_map = map_get(store, pkg);
        var pkg_obj = json_v_obj_new();
        var agents = map_keys(pkg_map);
        var an = vec_len(agents);
        var j = 0;
        while (j < an) {
            var agent = vec_get(agents, j);
            json_v_obj_set(pkg_obj, agent, _rating_to_jv(map_get(pkg_map, agent)));
            j = j + 1;
        }
        json_v_obj_set(o, pkg, pkg_obj);
        i = i + 1;
    }
    return json_v_build(o);
}

fn rstore_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    var store = rstore_new();
    var pn = json_v_obj_len(root);
    var i = 0;
    while (i < pn) {
        var pkg = json_v_obj_key(root, i);
        var pkg_in = json_v_obj_val(root, i);
        if (json_v_is_obj(pkg_in) == 1) {
            var pkg_map = map_new_str();
            var an = json_v_obj_len(pkg_in);
            var j = 0;
            while (j < an) {
                var agent = json_v_obj_key(pkg_in, j);
                var rv = json_v_obj_val(pkg_in, j);
                if (json_v_is_obj(rv) == 1) { map_set(pkg_map, agent, _rating_from_jv(rv)); }
                j = j + 1;
            }
            map_set(store, pkg, pkg_map);
        }
        i = i + 1;
    }
    return store;
}

# save(path) — write the store as JSON. Mirrors Rust `save`.
fn rstore_save(store, path: Str): i64 {
    var js = rstore_to_json(store);
    return file_write_all(str_data(path), str_data(js), str_len(js));
}

# load(path) — read a store; a missing file yields an empty store, a corrupt
# file yields 0 (error). Mirrors Rust `load`.
fn rstore_load(path: Str): i64 {
    if (file_exists(str_data(path)) == 0) { return rstore_new(); }
    var buf = alloc(RATINGS_MAXLEN);
    var n = file_read_all(str_data(path), buf, RATINGS_MAXLEN);
    if (n <= 0) { return rstore_new(); }
    return rstore_from_json(str_new(buf, n));
}

# --- flutter_packaging.cyr ---

# flutter_packaging.cyr — Flutter app packaging spec for `.agnos-agent` bundles.
#
# Ports rust-old/src/flutter_packaging.rs: the Flutter app manifest format,
# package layout, launch configuration, backend determination, env-var
# construction, and manifest validation. Pure logic — no deps.

# ---------------------------------------------------------------------------
# WaylandRequirement
# ---------------------------------------------------------------------------

var WL_CORE             = 0;
var WL_XDG_SHELL        = 1;
var WL_XDG_DECORATION   = 2;
var WL_TEXT_INPUT_V3    = 3;
var WL_DATA_DEVICE      = 4;
var WL_VIEWPORTER       = 5;
var WL_FRACTIONAL_SCALE = 6;
var WL_XWAYLAND         = 7;

fn wayland_req_name(w): Str {
    if (w == WL_CORE)             { return str_from("core"); }
    if (w == WL_XDG_SHELL)        { return str_from("xdg_shell"); }
    if (w == WL_XDG_DECORATION)   { return str_from("xdg_decoration"); }
    if (w == WL_TEXT_INPUT_V3)    { return str_from("text_input_v3"); }
    if (w == WL_DATA_DEVICE)      { return str_from("data_device"); }
    if (w == WL_VIEWPORTER)       { return str_from("viewporter"); }
    if (w == WL_FRACTIONAL_SCALE) { return str_from("fractional_scale"); }
    if (w == WL_XWAYLAND)         { return str_from("xwayland"); }
    return str_from("");
}

# ---------------------------------------------------------------------------
# DisplayBackend
# ---------------------------------------------------------------------------

var DB_WAYLAND  = 0;
var DB_XWAYLAND = 1;

fn display_backend_name(b): Str {
    if (b == DB_WAYLAND)  { return str_from("wayland"); }
    if (b == DB_XWAYLAND) { return str_from("xwayland"); }
    return str_from("");
}

# ---------------------------------------------------------------------------
# FlutterAppManifest
# ---------------------------------------------------------------------------
#
#   0 runtime (Str)  8 engine_version (Str)  16 dart_version (Str)
#   24 wayland_protocols (Vec<i64>)  32 platform_channels (Vec<Str>)  40 aot_compiled (i64)

fn fmanifest_new(runtime: Str, engine_version: Str, dart_version: Str,
                 wayland_protocols, platform_channels, aot_compiled): i64 {
    var m = alloc(48);
    store64(m,      runtime);
    store64(m + 8,  engine_version);
    store64(m + 16, dart_version);
    store64(m + 24, wayland_protocols);
    store64(m + 32, platform_channels);
    store64(m + 40, aot_compiled);
    return m;
}
fn fmanifest_runtime(m): Str        { return load64(m); }
fn fmanifest_engine_version(m): Str { return load64(m + 8); }
fn fmanifest_dart_version(m): Str   { return load64(m + 16); }
fn fmanifest_wayland(m)             { return load64(m + 24); }
fn fmanifest_channels(m)            { return load64(m + 32); }
fn fmanifest_aot_compiled(m): i64   { return load64(m + 40); }

# True if `vec` (of i64 requirement codes) contains `w`.
fn _wl_contains(vec, w): i64 {
    var n = vec_len(vec);
    var i = 0;
    var hit = 0;
    while (i < n) {
        if (vec_get(vec, i) == w) { hit = 1; }
        i = i + 1;
    }
    return hit;
}

# True if any platform channel contains `needle`.
fn _channel_contains(channels, needle: Str): i64 {
    var n = vec_len(channels);
    var i = 0;
    var hit = 0;
    while (i < n) {
        if (str_contains(vec_get(channels, i), needle) == 1) { hit = 1; }
        i = i + 1;
    }
    return hit;
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

# `x.y.z` with three non-empty all-digit parts. Mirrors Rust `is_dotted_version`.
fn is_dotted_version(v: Str): i64 {
    var n = str_len(v);
    var d = str_data(v);
    var segs = 0;
    var seg_len = 0;
    var bad = 0;
    var i = 0;
    while (i < n) {
        var c = load8(d + i) & 0xFF;
        if (c == 46) {                       # '.'
            if (seg_len == 0) { bad = 1; }
            segs = segs + 1;
            seg_len = 0;
        } else {
            if (c < 48) { bad = 1; }
            if (c > 57) { bad = 1; }
            seg_len = seg_len + 1;
        }
        i = i + 1;
    }
    if (seg_len == 0) { bad = 1; }
    segs = segs + 1;
    if (segs != 3) { return 0; }
    if (bad == 1) { return 0; }
    return 1;
}

# validate_flutter_manifest — Vec<Str> of errors (empty = valid). Mirrors Rust.
fn validate_flutter_manifest(m): i64 {
    var errors = vec_new();
    if (str_eq_cstr(fmanifest_runtime(m), "flutter") == 0) {
        vec_push(errors, str_from("runtime must be 'flutter'"));
    }
    var ev = fmanifest_engine_version(m);
    if (str_len(ev) == 0) {
        vec_push(errors, str_from("engine_version is required"));
    } else {
        if (is_dotted_version(ev) == 0) {
            vec_push(errors, str_from("engine_version is not a valid version (expected x.y.z)"));
        }
    }
    var dv = fmanifest_dart_version(m);
    if (str_len(dv) == 0) {
        vec_push(errors, str_from("dart_version is required"));
    } else {
        if (is_dotted_version(dv) == 0) {
            vec_push(errors, str_from("dart_version is not a valid version (expected x.y.z)"));
        }
    }
    if (_wl_contains(fmanifest_wayland(m), WL_CORE) == 0) {
        vec_push(errors, str_from("wayland_protocols must include Core"));
    }
    if (_wl_contains(fmanifest_wayland(m), WL_XDG_SHELL) == 0) {
        vec_push(errors, str_from("wayland_protocols must include XdgShell"));
    }
    return errors;
}

# ---------------------------------------------------------------------------
# Backend determination + launch config
# ---------------------------------------------------------------------------

# determine_backend — Wayland if every required protocol is in caps, else
# XWayland. Mirrors Rust `determine_backend`.
fn determine_backend(m, caps): i64 {
    var reqs = fmanifest_wayland(m);
    var n = vec_len(reqs);
    var i = 0;
    var all_met = 1;
    while (i < n) {
        if (_wl_contains(caps, vec_get(reqs, i)) == 0) { all_met = 0; }
        i = i + 1;
    }
    if (all_met == 1) { return DB_WAYLAND; }
    return DB_XWAYLAND;
}

# FlutterLaunchConfig
#   0 app_name (Str)  8 display_backend (i64)  16 compositor_socket (Str)
#   24 has_theme (i64)  32 theme_channel (Str)  40 accessibility_enabled (i64)  48 scale_factor (f64)
fn launch_app_name(c): Str          { return load64(c); }
fn launch_display_backend(c): i64   { return load64(c + 8); }
fn launch_compositor_socket(c): Str { return load64(c + 16); }
fn launch_has_theme(c): i64         { return load64(c + 24); }
fn launch_theme_channel(c): Str     { return load64(c + 32); }
fn launch_accessibility(c): i64     { return load64(c + 40); }
fn launch_scale_factor(c): i64      { return load64(c + 48); }   # f64 bits

# build_launch_config — XWayland backend if XWayland is required, else Wayland;
# theme channel if any channel mentions "theme"; accessibility if any mentions
# "accessibility". `scale` is an f64. Mirrors Rust `build_launch_config`.
fn build_launch_config(m, app_name: Str, compositor_socket: Str, scale): i64 {
    var backend = DB_WAYLAND;
    if (_wl_contains(fmanifest_wayland(m), WL_XWAYLAND) == 1) { backend = DB_XWAYLAND; }
    var has_theme = 0;
    var theme = str_from("");
    if (_channel_contains(fmanifest_channels(m), str_from("theme")) == 1) {
        has_theme = 1;
        theme = str_from("flutter/theme");
    }
    var access = _channel_contains(fmanifest_channels(m), str_from("accessibility"));
    var c = alloc(56);
    store64(c,      app_name);
    store64(c + 8,  backend);
    store64(c + 16, compositor_socket);
    store64(c + 24, has_theme);
    store64(c + 32, theme);
    store64(c + 40, access);
    store64(c + 48, scale);
    return c;
}

# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------

# build_env_vars — Str-keyed map of launch env vars. Mirrors Rust `build_env_vars`.
fn build_env_vars(c): i64 {
    var env = map_new_str();
    if (launch_display_backend(c) == DB_WAYLAND) {
        map_set(env, str_from("GDK_BACKEND"), str_from("wayland"));
        map_set(env, str_from("WAYLAND_DISPLAY"), launch_compositor_socket(c));
        map_set(env, str_from("FLUTTER_ENGINE_SWITCH_GL"), str_from("wayland"));
    } else {
        map_set(env, str_from("GDK_BACKEND"), str_from("x11"));
        map_set(env, str_from("DISPLAY"), str_from(":0"));
        map_set(env, str_from("FLUTTER_ENGINE_SWITCH_GL"), str_from("x11"));
    }
    # scale_factor formatted as a float string (matches Rust f64 to_string for the tested values)
    var scbuf[32];
    var sclen = fmt_float_buf(launch_scale_factor(c), &scbuf, 2);
    map_set(env, str_from("FLUTTER_FORCE_SCALE_FACTOR"), _trim_trailing_zeros(str_new(&scbuf, sclen)));
    if (launch_accessibility(c) == 1) {
        map_set(env, str_from("FLUTTER_ACCESSIBILITY"), str_from("true"));
    }
    if (launch_has_theme(c) == 1) {
        map_set(env, str_from("FLUTTER_THEME_CHANNEL"), launch_theme_channel(c));
    }
    map_set(env, str_from("AGNOS_APP_NAME"), launch_app_name(c));
    return env;
}

# Trim trailing zeros (and a trailing '.') from a decimal Str: "1.50"->"1.5",
# "1.00"->"1", "1.25"->"1.25". Rust's f64 to_string has no trailing zeros.
fn _trim_trailing_zeros(s: Str): Str {
    var n = str_len(s);
    var d = str_data(s);
    # only trim if there's a '.'
    var has_dot = 0;
    var i = 0;
    while (i < n) { if (load8(d + i) == 46) { has_dot = 1; } i = i + 1; }
    if (has_dot == 0) { return s; }
    var end = n;
    var go = 1;
    while (go == 1) {
        if (end == 0) { go = 0; }
        else {
            var c = load8(d + end - 1);
            if (c == 48) { end = end - 1; }            # trailing '0'
            else {
                if (c == 46) { end = end - 1; go = 0; } # trailing '.'
                else { go = 0; }
            }
        }
    }
    return str_sub(s, 0, end);
}

# ---------------------------------------------------------------------------
# Package layout
# ---------------------------------------------------------------------------
#
#   0 engine_path  8 app_binary_path  16 assets_path  24 manifest_path  32 sandbox_path

fn layout_for_app(app_name: Str): i64 {
    var l = alloc(40);
    store64(l,      str_from("bin/flutter_engine.so"));
    store64(l + 8,  str_cat(str_from("bin/"), app_name));
    store64(l + 16, str_from("assets/flutter_assets/"));
    store64(l + 24, str_from("manifest.json"));
    store64(l + 32, str_from("sandbox.json"));
    return l;
}
fn layout_engine_path(l): Str   { return load64(l); }
fn layout_app_binary_path(l): Str { return load64(l + 8); }
fn layout_assets_path(l): Str   { return load64(l + 16); }
fn layout_manifest_path(l): Str { return load64(l + 24); }
fn layout_sandbox_path(l): Str  { return load64(l + 32); }

# --- flutter_agpkg.cyr ---

# flutter_agpkg.cyr — pack a Flutter build dir into a `.agnos-agent` bundle.
#
# Ports rust-old/src/flutter_agpkg.rs: build-directory validation, the pack
# config, marketplace-manifest + sandbox-profile generation, and (in the archive
# section, below) the gzip+tar packer. LandlockRule / NetworkRule are reused from
# sandbox_profiles.cyr (ll_new / nr_new) — the unification ADR-0007 anticipated.

# ---------------------------------------------------------------------------
# PackFlutterConfig
# ---------------------------------------------------------------------------
#
#   0 app_name (Str)  8 version (Str)  16 publisher (Str)  24 description (Str)
#   32 category (i64)  40 wayland_requirements (Vec)  48 network_access (i64)
#   56 has_data_dir (i64)  64 data_dir (Str)

fn pfconfig_new(app_name: Str, version: Str, publisher: Str, description: Str,
                category, wayland_requirements, network_access, has_data_dir, data_dir: Str): i64 {
    var c = alloc(72);
    store64(c,      app_name);
    store64(c + 8,  version);
    store64(c + 16, publisher);
    store64(c + 24, description);
    store64(c + 32, category);
    store64(c + 40, wayland_requirements);
    store64(c + 48, network_access);
    store64(c + 56, has_data_dir);
    store64(c + 64, data_dir);
    return c;
}
fn pfconfig_app_name(c): Str     { return load64(c); }
fn pfconfig_version(c): Str      { return load64(c + 8); }
fn pfconfig_publisher(c): Str    { return load64(c + 16); }
fn pfconfig_description(c): Str  { return load64(c + 24); }
fn pfconfig_category(c): i64     { return load64(c + 32); }
fn pfconfig_wayland(c)           { return load64(c + 40); }
fn pfconfig_network_access(c): i64 { return load64(c + 48); }
fn pfconfig_has_data_dir(c): i64 { return load64(c + 56); }
fn pfconfig_data_dir(c): Str     { return load64(c + 64); }

fn _ag_jstr(o, key): Str {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return str_from(""); }
    if (json_v_is_str(v) == 0) { return str_from(""); }
    return json_v_str(v);
}
fn _ag_jbool(o, key): i64 {
    var v = json_v_obj_get(o, key);
    if (v == 0) { return 0; }
    if (json_v_is_bool(v) == 0) { return 0; }
    return json_v_bool(v);
}

# config_from_json — category defaults to DesktopApp; network_access false;
# data_dir none (serde defaults). Mirrors Rust `PackFlutterConfig` deserialize.
fn pfconfig_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }

    var category = CAT_DESKTOP_APP;                 # default_category()
    var cv = json_v_obj_get(root, "category");
    if (json_v_is_str(cv) == 1) { category = cat_json_parse(json_v_str(cv)); }

    var wl = vec_new();
    var wv = json_v_obj_get(root, "wayland_requirements");
    if (json_v_is_arr(wv) == 1) {
        var n = json_v_arr_len(wv);
        var i = 0;
        while (i < n) {
            var el = json_v_arr_get(wv, i);
            if (json_v_is_str(el) == 1) { vec_push(wl, _wl_json_parse(json_v_str(el))); }
            i = i + 1;
        }
    }

    var has_dd = 0;
    var dd = str_from("");
    var ddv = json_v_obj_get(root, "data_dir");
    if (json_v_is_str(ddv) == 1) { has_dd = 1; dd = json_v_str(ddv); }

    return pfconfig_new(_ag_jstr(root, "app_name"), _ag_jstr(root, "version"),
                        _ag_jstr(root, "publisher"), _ag_jstr(root, "description"),
                        category, wl, _ag_jbool(root, "network_access"), has_dd, dd);
}

# WaylandRequirement serde variant name -> code (PascalCase).
fn _wl_json_parse(s: Str): i64 {
    if (str_eq_cstr(s, "Core") == 1)            { return WL_CORE; }
    if (str_eq_cstr(s, "XdgShell") == 1)        { return WL_XDG_SHELL; }
    if (str_eq_cstr(s, "XdgDecoration") == 1)   { return WL_XDG_DECORATION; }
    if (str_eq_cstr(s, "TextInputV3") == 1)     { return WL_TEXT_INPUT_V3; }
    if (str_eq_cstr(s, "DataDevice") == 1)      { return WL_DATA_DEVICE; }
    if (str_eq_cstr(s, "Viewporter") == 1)      { return WL_VIEWPORTER; }
    if (str_eq_cstr(s, "FractionalScale") == 1) { return WL_FRACTIONAL_SCALE; }
    if (str_eq_cstr(s, "XWayland") == 1)        { return WL_XWAYLAND; }
    return WL_CORE;
}

# ---------------------------------------------------------------------------
# SandboxProfile (agpkg flavour: { landlock_paths, seccomp_mode, network })
# ---------------------------------------------------------------------------

fn sbprofile_new(landlock_paths, seccomp_mode: Str, network): i64 {
    var s = alloc(24);
    store64(s,      landlock_paths);
    store64(s + 8,  seccomp_mode);
    store64(s + 16, network);
    return s;
}
fn sbprofile_landlock_paths(s)     { return load64(s); }
fn sbprofile_seccomp_mode(s): Str  { return load64(s + 8); }
fn sbprofile_network(s)            { return load64(s + 16); }

fn sbprofile_has_rule(s, path: Str, access: Str): i64 {
    var rules = sbprofile_landlock_paths(s);
    var n = vec_len(rules);
    var i = 0;
    var hit = 0;
    while (i < n) {
        if (hit == 0) {
            var r = vec_get(rules, i);
            if (str_eq(ll_path(r), path) == 1) {
                if (str_eq(ll_access(r), access) == 1) { hit = 1; }
            }
        }
        i = i + 1;
    }
    return hit;
}

# ---------------------------------------------------------------------------
# Build directory validation
# ---------------------------------------------------------------------------

# True if `path` is an existing regular file (exists but not a directory).
fn _is_file(path: Str): i64 {
    if (file_exists(str_data(path)) == 0) { return 0; }
    if (is_dir(path) == 1) { return 0; }
    return 1;
}

# find_aot_binary — relative path Str of app.so / libapp.so in root or lib/, or 0.
fn _find_aot(root: Str): i64 {
    if (_is_file(path_join(root, str_from("app.so"))) == 1)        { return str_from("app.so"); }
    if (_is_file(path_join(root, str_from("libapp.so"))) == 1)     { return str_from("libapp.so"); }
    if (_is_file(path_join(root, str_from("lib/app.so"))) == 1)    { return str_from("lib/app.so"); }
    if (_is_file(path_join(root, str_from("lib/libapp.so"))) == 1) { return str_from("lib/libapp.so"); }
    return 0;
}

# FlutterBuildDir: 0 root  8 engine_lib  16 has_aot  24 aot_binary  32 assets_dir
fn fbuild_root(b): Str       { return load64(b); }
fn fbuild_engine_lib(b): Str { return load64(b + 8); }
fn fbuild_has_aot(b): i64    { return load64(b + 16); }
fn fbuild_aot_binary(b): Str { return load64(b + 24); }
fn fbuild_assets_dir(b): Str { return load64(b + 32); }

# validate result: 0 ok (i64)  8 error (Str)  16 build (FlutterBuildDir* or 0)
fn fbres_ok(r): i64      { return load64(r); }
fn fbres_error(r): Str   { return load64(r + 8); }
fn fbres_build(r)        { return load64(r + 16); }

# FlutterBuildDir::validate — checks the engine lib, AOT binary, and
# flutter_assets/ dir. Mirrors Rust `FlutterBuildDir::validate`.
fn fbuild_validate(root: Str): i64 {
    var res = alloc(24);
    store64(res,      0);
    store64(res + 8,  str_from(""));
    store64(res + 16, 0);

    if (is_dir(root) == 0) {
        store64(res + 8, str_from("build directory does not exist"));
        return res;
    }

    var engine = str_from("");
    var has_engine = 0;
    if (_is_file(path_join(root, str_from("lib/libflutter_engine.so"))) == 1) {
        engine = str_from("lib/libflutter_engine.so");
        has_engine = 1;
    } else {
        if (_is_file(path_join(root, str_from("lib/libflutter_linux_gtk.so"))) == 1) {
            engine = str_from("lib/libflutter_linux_gtk.so");
            has_engine = 1;
        }
    }
    if (has_engine == 0) {
        store64(res + 8, str_from("missing Flutter engine shared library"));
        return res;
    }

    var aot = _find_aot(root);
    var has_aot = 0;
    var aot_s = str_from("");
    if (aot != 0) { has_aot = 1; aot_s = aot; }

    if (is_dir(path_join(root, str_from("flutter_assets"))) == 0) {
        store64(res + 8, str_from("missing flutter_assets/ directory"));
        return res;
    }

    var build = alloc(40);
    store64(build,      root);
    store64(build + 8,  engine);
    store64(build + 16, has_aot);
    store64(build + 24, aot_s);
    store64(build + 32, str_from("flutter_assets"));
    store64(res, 1);
    store64(res + 16, build);
    return res;
}

# ---------------------------------------------------------------------------
# Manifest + sandbox-profile generation
# ---------------------------------------------------------------------------

# generate_manifest — MarketplaceManifest from the pack config (runtime
# "flutter", tags [flutter, desktop]). Mirrors Rust `generate_manifest`.
fn generate_manifest(config): i64 {
    var agent = agent_manifest_new(pfconfig_app_name(config));
    store64(agent + 8,  pfconfig_description(config));   # description
    store64(agent + 16, pfconfig_publisher(config));     # author
    var publisher = publisher_new(pfconfig_publisher(config), str_from(""), str_from(""));
    var m = mela_manifest_new(agent, publisher, pfconfig_category(config), pfconfig_version(config));
    man_set_runtime(m, str_from("flutter"));
    vec_push(man_tags(m), str_from("flutter"));
    vec_push(man_tags(m), str_from("desktop"));
    return m;
}

# generate_sandbox_profile — landlock data/tmp/fonts (+/run/user/ if any wayland
# requirement), desktop seccomp, network per network_access. Mirrors Rust.
fn generate_sandbox_profile(config): i64 {
    var data_dir = str_from("");
    if (pfconfig_has_data_dir(config) == 1) {
        data_dir = pfconfig_data_dir(config);
    } else {
        data_dir = str_cat(str_cat(str_from("~/.local/share/"), pfconfig_app_name(config)), str_from("/"));
    }
    var rules = vec_new();
    vec_push(rules, ll_new(data_dir, str_from("rw")));
    vec_push(rules, ll_new(str_from("/tmp"), str_from("rw")));
    vec_push(rules, ll_new(str_from("/usr/share/fonts"), str_from("ro")));
    if (vec_len(pfconfig_wayland(config)) != 0) {
        vec_push(rules, ll_new(str_from("/run/user/"), str_from("ro")));
    }
    var network = nr_new(0, vec_new());
    if (pfconfig_network_access(config) == 1) {
        var hosts = vec_new();
        vec_push(hosts, str_from("*"));
        network = nr_new(1, hosts);
    }
    return sbprofile_new(rules, str_from("desktop"), network);
}

# sandbox-profile JSON (landlock_paths / seccomp_mode / network).
fn sbprofile_to_json(s): Str {
    var o = json_v_obj_new();
    var arr = json_v_arr_new();
    var rules = sbprofile_landlock_paths(s);
    var n = vec_len(rules);
    var i = 0;
    while (i < n) {
        var r = vec_get(rules, i);
        var ro = json_v_obj_new();
        json_v_obj_set(ro, str_from("path"),   json_v_str_new(ll_path(r)));
        json_v_obj_set(ro, str_from("access"), json_v_str_new(ll_access(r)));
        json_v_arr_push(arr, ro);
        i = i + 1;
    }
    json_v_obj_set(o, str_from("landlock_paths"), arr);
    json_v_obj_set(o, str_from("seccomp_mode"),   json_v_str_new(sbprofile_seccomp_mode(s)));
    var net = sbprofile_network(s);
    var no = json_v_obj_new();
    json_v_obj_set(no, str_from("enabled"), json_v_bool_new(nr_enabled(net)));
    var ha = json_v_arr_new();
    var hosts = nr_hosts(net);
    var hn = vec_len(hosts);
    var hi = 0;
    while (hi < hn) { json_v_arr_push(ha, json_v_str_new(vec_get(hosts, hi))); hi = hi + 1; }
    json_v_obj_set(no, str_from("allowed_hosts"), ha);
    json_v_obj_set(o, str_from("network"), no);
    return json_v_build(o);
}

fn sbprofile_from_json(json: Str): i64 {
    var root = json_v_parse_str(str_data(json), str_len(json));
    if (root == 0) { return 0; }
    if (json_v_is_obj(root) == 0) { return 0; }
    var rules = vec_new();
    var arr = json_v_obj_get(root, "landlock_paths");
    if (json_v_is_arr(arr) == 1) {
        var n = json_v_arr_len(arr);
        var i = 0;
        while (i < n) {
            var ro = json_v_arr_get(arr, i);
            vec_push(rules, ll_new(_ag_jstr(ro, "path"), _ag_jstr(ro, "access")));
            i = i + 1;
        }
    }
    var hosts = vec_new();
    var enabled = 0;
    var net_in = json_v_obj_get(root, "network");
    if (json_v_is_obj(net_in) == 1) {
        enabled = _ag_jbool(net_in, "enabled");
        var ha = json_v_obj_get(net_in, "allowed_hosts");
        if (json_v_is_arr(ha) == 1) {
            var hn = json_v_arr_len(ha);
            var hi = 0;
            while (hi < hn) {
                var el = json_v_arr_get(ha, hi);
                if (json_v_is_str(el) == 1) { vec_push(hosts, json_v_str(el)); }
                hi = hi + 1;
            }
        }
    }
    return sbprofile_new(rules, _ag_jstr(root, "seccomp_mode"), nr_new(enabled, hosts));
}

# ---------------------------------------------------------------------------
# Archive: ustar tar (hand-rolled) over sankoch gzip
# ---------------------------------------------------------------------------
#
# sankoch is compression-only, so the tar container is implemented here. Output
# is a standard gzipped ustar archive — readable by GNU tar, and able to read
# GNU-tar-built archives (cross-validation, ADR-0008). Replaces Rust tar+flate2.

var AGPKG_BUF_MAXLEN = 8388608;     # 8 MiB working buffers

# Round n up to a 512-byte multiple.
fn _roundup512(n): i64 { return ((n + 511) / 512) * 512; }

# tar entry: 0 name (Str)  8 data (ptr)  16 len (i64)
fn tentry_new(name: Str, data, len): i64 {
    var e = alloc(24);
    store64(e,      name);
    store64(e + 8,  data);
    store64(e + 16, len);
    return e;
}
fn tentry_name(e): Str { return load64(e); }
fn tentry_data(e)      { return load64(e + 8); }
fn tentry_len(e): i64  { return load64(e + 16); }

# Write `val` as a NUL-terminated octal field of `width` bytes (width-1 digits,
# zero-padded) at buf+off.
fn _tar_octal(buf, off, width, val): i64 {
    var k = 0;
    while (k < width - 1) { store8(buf + off + k, 48); k = k + 1; }   # '0'
    store8(buf + off + width - 1, 0);                                  # NUL
    var v = val;
    var i = width - 2;
    while (i >= 0) {
        if (v > 0) {
            store8(buf + off + i, 48 + (v & 7));
            v = v >> 3;
            i = i - 1;
        } else {
            i = 0 - 1;
        }
    }
    return 0;
}

# Write a 512-byte ustar header for a regular file at buf+off.
fn _tar_header(buf, off, name: Str, size): i64 {
    var i = 0;
    while (i < 512) { store8(buf + off + i, 0); i = i + 1; }
    var nlen = str_len(name);
    if (nlen > 100) { nlen = 100; }
    memcpy(buf + off, str_data(name), nlen);
    _tar_octal(buf, off + 100, 8, 0x1A4);   # mode 0o644
    _tar_octal(buf, off + 108, 8, 0);        # uid
    _tar_octal(buf, off + 116, 8, 0);        # gid
    _tar_octal(buf, off + 124, 12, size);    # size
    _tar_octal(buf, off + 136, 12, 0);       # mtime
    store8(buf + off + 156, 48);             # typeflag '0' (regular file)
    # magic "ustar\0" + version "00"
    store8(buf + off + 257, 117); store8(buf + off + 258, 115); store8(buf + off + 259, 116);
    store8(buf + off + 260, 97);  store8(buf + off + 261, 114); store8(buf + off + 262, 0);
    store8(buf + off + 263, 48);  store8(buf + off + 264, 48);
    # checksum over header with chksum field as 8 spaces
    var c = 0;
    while (c < 8) { store8(buf + off + 148 + c, 32); c = c + 1; }
    var sum = 0;
    var j = 0;
    while (j < 512) { sum = sum + (load8(buf + off + j) & 0xFF); j = j + 1; }
    _tar_octal(buf, off + 148, 7, sum);      # 6 octal digits + NUL
    store8(buf + off + 148 + 7, 32);         # trailing space
    return 0;
}

# Build a ustar archive (Str) from a Vec of tar entries.
fn _tar_build(entries): Str {
    var n = vec_len(entries);
    var total = 0;
    var i = 0;
    while (i < n) {
        total = total + 512 + _roundup512(tentry_len(vec_get(entries, i)));
        i = i + 1;
    }
    total = total + 1024;                    # two zero blocks (EOF)
    var buf = alloc(total);
    var z = 0;
    while (z < total) { store8(buf + z, 0); z = z + 1; }
    var off = 0;
    i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var len = tentry_len(e);
        _tar_header(buf, off, tentry_name(e), len);
        memcpy(buf + off + 512, tentry_data(e), len);
        off = off + 512 + _roundup512(len);
        i = i + 1;
    }
    return str_new(buf, total);
}

# gzip a Str -> Str (or 0 on error).
fn _gzip_str(s: Str): i64 {
    var cap = str_len(s) + 65536;
    var dst = alloc(cap);
    var clen = gzip_compress(str_data(s), str_len(s), dst, cap);
    if (clen < 0) { return 0; }
    return str_new(dst, clen);
}

# Read an entire file into a Str, or 0 on error.
fn _read_file(path: Str): i64 {
    if (file_exists(str_data(path)) == 0) { return 0; }
    var buf = alloc(AGPKG_BUF_MAXLEN);
    var n = file_read_all(str_data(path), buf, AGPKG_BUF_MAXLEN);
    if (n < 0) { return 0; }
    return str_new(buf, n);
}

# pack_flutter_app — validate the build dir, then write
# <output_dir>/<app>-<version>.agnos-agent (gzipped ustar) containing
# bin/flutter_engine.so, bin/<app> (if AOT), assets/flutter_assets/<files>,
# manifest.json, sandbox.json. Returns the tarball path Str, or 0 on failure.
# Mirrors Rust `pack_flutter_app` (asset walk is one level — the build layout).
fn pack_flutter_app(build_dir: Str, config, output_dir: Str): i64 {
    var res = fbuild_validate(build_dir);
    if (fbres_ok(res) == 0) { return 0; }
    var b = fbres_build(res);

    var entries = vec_new();

    var engine_bytes = _read_file(path_join(build_dir, fbuild_engine_lib(b)));
    if (engine_bytes == 0) { return 0; }
    vec_push(entries, tentry_new(str_from("bin/flutter_engine.so"),
                                 str_data(engine_bytes), str_len(engine_bytes)));

    if (fbuild_has_aot(b) == 1) {
        var aot_bytes = _read_file(path_join(build_dir, fbuild_aot_binary(b)));
        if (aot_bytes != 0) {
            vec_push(entries, tentry_new(str_cat(str_from("bin/"), pfconfig_app_name(config)),
                                         str_data(aot_bytes), str_len(aot_bytes)));
        }
    }

    var assets_src = path_join(build_dir, fbuild_assets_dir(b));
    var names = dir_list(assets_src);
    var an = vec_len(names);
    var ai = 0;
    while (ai < an) {
        var nm = vec_get(names, ai);
        var fpath = path_join(assets_src, nm);
        if (_is_file(fpath) == 1) {
            var fb = _read_file(fpath);
            if (fb != 0) {
                vec_push(entries, tentry_new(str_cat(str_from("assets/flutter_assets/"), nm),
                                             str_data(fb), str_len(fb)));
            }
        }
        ai = ai + 1;
    }

    var manifest_json = mela_manifest_to_json(generate_manifest(config));
    vec_push(entries, tentry_new(str_from("manifest.json"), str_data(manifest_json), str_len(manifest_json)));
    var sandbox_json = sbprofile_to_json(generate_sandbox_profile(config));
    vec_push(entries, tentry_new(str_from("sandbox.json"), str_data(sandbox_json), str_len(sandbox_json)));

    var gz = _gzip_str(_tar_build(entries));
    if (gz == 0) { return 0; }
    _rc_mkdir_p(output_dir);
    var tarball_name = str_cat(str_cat(str_cat(pfconfig_app_name(config), str_from("-")),
                                       pfconfig_version(config)), str_from(".agnos-agent"));
    var out_path = path_join(output_dir, tarball_name);
    if (file_write_all(str_data(out_path), str_data(gz), str_len(gz)) < 0) { return 0; }
    return out_path;
}

# --- tar reading (for inspect) ---

fn _tar_field_len(buf, off, max): i64 {
    var i = 0;
    var done = 0;
    var len = max;
    while (i < max) {
        if (done == 0) {
            if (load8(buf + off + i) == 0) { done = 1; len = i; }
        }
        i = i + 1;
    }
    return len;
}

fn _tar_read_name(buf, off): Str {
    var len = _tar_field_len(buf, off, 100);
    var nb = alloc(len + 1);
    memcpy(nb, buf + off, len);
    store8(nb + len, 0);
    return str_new(nb, len);
}

# Parse the octal size field (offset 124, 12 bytes; stops at NUL/space).
fn _tar_read_size(buf, off): i64 {
    var v = 0;
    var i = 0;
    var done = 0;
    while (i < 12) {
        if (done == 0) {
            var c = load8(buf + off + 124 + i) & 0xFF;
            if (c == 0) { done = 1; }
            else {
                if (c == 32) { done = 1; }
                else { v = v * 8 + (c - 48); }
            }
        }
        i = i + 1;
    }
    return v;
}

# agpkg_inspect — gunzip + parse the ustar archive at `path`, returning a Vec of
# entry-name Strs (or 0 on read/decompress error). The validate half of
# build→inspect→validate, and the reader used for GNU-tar cross-validation.
fn agpkg_inspect(path: Str): i64 {
    var fb = _read_file(path);
    if (fb == 0) { return 0; }
    return agpkg_inspect_bytes(str_data(fb), str_len(fb));
}

# _tar_entry_safe — reject tar entries that would enable a zip-slip / symlink
# escape on extraction (defense-in-depth, hardening per the v0.9.0 audit; cf.
# CVE-2025-45582, tar-fs CVE-2024-12905, the mholt/archiver zip-slip class). An
# entry is safe only if it is a regular file ('0' or the old-style NUL typeflag)
# and its name is relative with no ".." segment and no leading '/'.
fn _tar_entry_safe(buf, off): i64 {
    var tf = load8(buf + off + 156);             # typeflag
    if (tf != 48) {                              # '0' regular
        if (tf != 0) { return 0; }               # reject symlink('2')/hardlink('1')/dir('5')/...
    }
    var name = _tar_read_name(buf, off);
    if (str_len(name) == 0) { return 0; }
    if (load8(str_data(name)) == 47) { return 0; }            # leading '/' (absolute)
    if (str_contains(name, str_from("..")) == 1) { return 0; } # any ".." (traversal)
    return 1;
}

# agpkg_read_entry — gunzip + find the entry named `name`, returning its content
# bytes as a Str (or 0 if absent / on a decompress error). Bounds-checked. Used
# to pull manifest.json / sandbox.json back out of a packed bundle (backs the
# local_registry on-disk extraction, ADR-0005 — now implemented).
fn agpkg_read_entry(data, len, name: Str): i64 {
    var dst = alloc(AGPKG_BUF_MAXLEN);
    var dlen = gzip_decompress(data, len, dst, AGPKG_BUF_MAXLEN);
    if (dlen < 0) { return 0; }
    var off = 0;
    var go = 1;
    var found = 0;
    while (go == 1) {
        if (off + 512 > dlen) { go = 0; }
        else {
            if (load8(dst + off) == 0) { go = 0; }
            else {
                var esize = _tar_read_size(dst, off);
                if (str_eq(_tar_read_name(dst, off), name) == 1) {
                    # only return content for a safe regular-file entry
                    if (_tar_entry_safe(dst, off) == 1) {
                        if (off + 512 + esize <= dlen) {
                            var out = alloc(esize + 1);
                            memcpy(out, dst + off + 512, esize);
                            store8(out + esize, 0);
                            found = str_new(out, esize);
                        }
                    }
                    go = 0;
                } else {
                    off = off + 512 + _roundup512(esize);
                }
            }
        }
    }
    return found;
}

# agpkg_extract_to_dir — gunzip + extract every safe regular-file entry of the
# bundle to disk under `dest` (creating parent dirs), applying the zip-slip /
# symlink guard per entry. Returns the number of files written, or -1 on a
# decompress error. This is the real on-disk extractor (closes ADR-0005).
fn agpkg_extract_to_dir(data, len, dest: Str): i64 {
    var dst = alloc(AGPKG_BUF_MAXLEN);
    var dlen = gzip_decompress(data, len, dst, AGPKG_BUF_MAXLEN);
    if (dlen < 0) { return 0 - 1; }
    _rc_mkdir_p(dest);
    var off = 0;
    var go = 1;
    var count = 0;
    while (go == 1) {
        if (off + 512 > dlen) { go = 0; }
        else {
            if (load8(dst + off) == 0) { go = 0; }
            else {
                var esize = _tar_read_size(dst, off);
                if (_tar_entry_safe(dst, off) == 1) {       # zip-slip / symlink guard
                    if (off + 512 + esize <= dlen) {
                        var outpath = path_join(dest, _tar_read_name(dst, off));
                        _rc_mkdir_p(path_dirname(outpath));   # ensure parent dirs
                        if (file_write_all(str_data(outpath), dst + off + 512, esize) >= 0) {
                            count = count + 1;
                        }
                    }
                }
                off = off + 512 + _roundup512(esize);
            }
        }
    }
    return count;
}

# Gunzip + parse a gzipped-ustar byte buffer; returns a Vec of entry-name Strs,
# or 0 on a decompress error. Robust to arbitrary input (bounds-checked) — the
# fuzz entry point.
fn agpkg_inspect_bytes(data, len): i64 {
    var dst = alloc(AGPKG_BUF_MAXLEN);
    var dlen = gzip_decompress(data, len, dst, AGPKG_BUF_MAXLEN);
    if (dlen < 0) { return 0; }
    var names = vec_new();
    var off = 0;
    var go = 1;
    while (go == 1) {
        if (off + 512 > dlen) { go = 0; }
        else {
            if (load8(dst + off) == 0) { go = 0; }     # zero block => EOF
            else {
                # only list safe regular-file entries (zip-slip / symlink escapes
                # are skipped, not surfaced as installable — v0.9.0 hardening)
                if (_tar_entry_safe(dst, off) == 1) { vec_push(names, _tar_read_name(dst, off)); }
                off = off + 512 + _roundup512(_tar_read_size(dst, off));
            }
        }
    }
    return names;
}

# --- pipeline.cyr ---

# pipeline.cyr — end-to-end marketplace flow (v0.8.1).
#
# Wires the full path across the ported modules:
#   package (flutter_agpkg) -> sign (trust) -> log (transparency)
#   -> distribute -> verify (trust) -> capability-surface (sandbox)
#   -> install (local_registry).
#
# Both trust gates are ENFORCED at install, not merely present:
#   gate 1 — Ed25519 signature over the bundle bytes, keyed by the manifest's
#            publisher key_id resolved against the keyring;
#   gate 2 — SHA-256 content digest (download integrity).
#
# Included last, so it can reference every module. The end-to-end demonstration
# moves the signed bundle + signature as values; the live network counterpart is
# `remote_client` (rc_publish uploads, rc_download fetches+writes — both real over
# sandhi). pipeline_install verifies both gates then extracts to disk.

# package — build a gzipped-ustar `.agnos-agent` bundle (bytes Str) from a
# manifest + sandbox profile. The publishable/distributable artifact.
fn pipeline_package(manifest, sandbox): i64 {
    var entries = vec_new();
    var mjson = mela_manifest_to_json(manifest);
    vec_push(entries, tentry_new(str_from("manifest.json"), str_data(mjson), str_len(mjson)));
    var sjson = sbprofile_to_json(sandbox);
    vec_push(entries, tentry_new(str_from("sandbox.json"), str_data(sjson), str_len(sjson)));
    return _gzip_str(_tar_build(entries));
}

# extract the MarketplaceManifest from a bundle, or 0.
fn pipeline_extract_manifest(bundle): i64 {
    var mjson = agpkg_read_entry(str_data(bundle), str_len(bundle), str_from("manifest.json"));
    if (mjson == 0) { return 0; }
    return manifest_from_json(mjson);
}

# extract the sandbox SandboxProfile from a bundle, or 0 (the capability surface
# disclosed before install).
fn pipeline_extract_sandbox(bundle): i64 {
    var sjson = agpkg_read_entry(str_data(bundle), str_len(bundle), str_from("sandbox.json"));
    if (sjson == 0) { return 0; }
    return sbprofile_from_json(sjson);
}

# publish — sign the bundle and append it to the transparency log. Writes the
# 64-byte signature to `sig_out` and returns the log entry.
fn pipeline_publish(tlog, bundle, sk, sig_out, now): i64 {
    ed25519_sign(sk, str_data(bundle), str_len(bundle), sig_out);
    var content_hash = trust_hash_data(str_data(bundle), str_len(bundle));
    var sig_hash = trust_hash_data(sig_out, 64);
    var manifest = pipeline_extract_manifest(bundle);
    var pkg = str_from("unknown");
    var ver = str_from("0.0.0");
    var kid = str_from("");
    if (manifest != 0) {
        pkg = manifest_qualified_name(manifest);
        ver = man_version(manifest);
        kid = pub_key_id(man_publisher(manifest));
    }
    return tlog_append(tlog, pkg, ver, kid, content_hash, sig_hash, now);
}

# install — verify a downloaded bundle and record it, enforcing BOTH gates.
# Returns the install result, or 0 on any of: malformed bundle, unknown/invalid
# publisher key, bad signature (gate 1), digest mismatch (gate 2), invalid
# manifest. `expected_hash` of "" skips the digest comparison (compute + record
# only); a non-empty value must match the bundle's SHA-256.
fn pipeline_install(reg, keyring, bundle, sig, sig_len, expected_hash: Str, now): i64 {
    var data = str_data(bundle);
    var len = str_len(bundle);

    var manifest = pipeline_extract_manifest(bundle);
    if (manifest == 0) { return 0; }

    # gate 1 — Ed25519 signature over the bundle, keyed by publisher key_id
    var key_id = pub_key_id(man_publisher(manifest));
    if (registry_verify_package(keyring, key_id, data, len, sig, sig_len, now) == 0) { return 0; }

    # gate 2 — content digest
    var package_hash = trust_hash_data(data, len);
    if (str_len(expected_hash) != 0) {
        if (str_eq(package_hash, expected_hash) == 0) { return 0; }
    }

    if (vec_len(manifest_validate(manifest)) != 0) { return 0; }
    var res = registry_install(reg, manifest, package_hash, len, now);
    if (res != 0) {
        # actually unpack the bundle onto disk under the install dir (real
        # extraction, ADR-0005; the zip-slip guard runs per entry). A no-op for
        # an in-memory registry (/dev/null root) — file writes just fail closed.
        agpkg_extract_to_dir(data, len, instres_install_dir(res));
    }
    return res;
}
